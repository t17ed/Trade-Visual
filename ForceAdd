-- ============================================================
--  STATUS HELPERS
-- ============================================================
local DOT_COLS = {
    idle    = Color3.fromRGB(55,  55,  75),
    flying  = Color3.fromRGB(80, 205, 115),
    wall    = Color3.fromRGB(255, 185,  55),
    travel  = Color3.fromRGB(90, 140, 255),
    arrived = Color3.fromRGB(255,  90, 185),
    error   = Color3.fromRGB(220,  65,  75),
}
function setStatus(text, state)   -- hoisted so fly loop can call it
    statusLbl.Text = text
    TweenService:Create(dot,TweenInfo.new(0.2),{BackgroundColor3=DOT_COLS[state or "idle"]}):Play()
end
local function savedPosText()
    return savedPos
        and ("Saved: %.0f, %.0f, %.0f"):format(savedPos.X, savedPos.Y, savedPos.Z)
        or  "No position saved"
end

-- ============================================================
--  BUTTON CALLBACKS
-- ============================================================

-- ── Fly toggle ───────────────────────────────────────────────
flyBtn.MouseButton1Click:Connect(function()
    flyEnabled = not flyEnabled
    if flyEnabled then
        startFly()
        flyBtn.Text = "🔮  Fly: ON"
        TweenService:Create(flyBtn,TweenInfo.new(0.2),
            {BackgroundColor3=Color3.fromRGB(160,60,200)}):Play()   -- purple-pink
    else
        stopFly()
        flyBtn.Text = "🔮  Fly: OFF"
        TweenService:Create(flyBtn,TweenInfo.new(0.2),
            {BackgroundColor3=Color3.fromRGB(52,52,80)}):Play()
        setStatus(savedPosText(), "idle")
    end
end)

-- ── Save position ────────────────────────────────────────────
saveBtn.MouseButton1Click:Connect(function()
    local hrp = getHRP(); if not hrp then return end
    savedPos  = hrp.Position
    setStatus(savedPosText(), flyEnabled and "flying" or "idle")

    TweenService:Create(saveBtn,TweenInfo.new(0.1),
        {BackgroundColor3=Color3.fromRGB(75,220,135)}):Play()
    task.delay(0.3, function()
        TweenService:Create(saveBtn,TweenInfo.new(0.25),
            {BackgroundColor3=Color3.fromRGB(38,115,82)}):Play()
    end)
end)

-- ── Load position ────────────────────────────────────────────
loadBtn.MouseButton1Click:Connect(function()
    if not savedPos then
        setStatus("Save a position first!", "error")
        local orig = loadBtn.Position
        for i = 1, 6 do
            task.delay(i * 0.055, function()
                loadBtn.Position = orig + UDim2.new(0, i%2==0 and 5 or -5, 0, 0)
            end)
        end
        task.delay(0.38, function() loadBtn.Position = orig end)
        task.delay(1.5,  function() setStatus(savedPosText(), flyEnabled and "flying" or "idle") end)
        return
    end

    -- Auto-enable fly if off
    if not flyEnabled then
        flyEnabled = true
        startFly()
        flyBtn.Text = "🔮  Fly: ON"
        TweenService:Create(flyBtn,TweenInfo.new(0.2),
            {BackgroundColor3=Color3.fromRGB(160,60,200)}):Play()
    end

    spinning  = false   -- cancel any ongoing spin
    traveling = true
    setStatus("Starting travel...", "travel")

    TweenService:Create(loadBtn,TweenInfo.new(0.1),
        {BackgroundColor3=Color3.fromRGB(120,90,220)}):Play()
    task.delay(0.3, function()
        TweenService:Create(loadBtn,TweenInfo.new(0.25),
            {BackgroundColor3=Color3.fromRGB(76,50,162)}):Play()
    end)
end)

-- ============================================================
--  CLEANUP ON RESPAWN
-- ============================================================
LP.CharacterAdded:Connect(function()
    flyEnabled = false
    traveling  = false
    launching  = false
    spinning   = false
    if flyConn    then flyConn:Disconnect();    flyConn    = nil end
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
    removeGhost()

    flyBtn.Text = "🔮  Fly: OFF"
    TweenService:Create(flyBtn,TweenInfo.new(0.2),
        {BackgroundColor3=Color3.fromRGB(52,52,80)}):Play()
    setStatus(savedPosText(), "idle")
end)
