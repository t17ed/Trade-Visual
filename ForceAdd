-- ┌──────────────────────────────────────────────────────┐
-- │   Fly + Save / Load Position  |  LocalScript         │
-- │   Place in StarterPlayerScripts                      │
-- │                                                      │
-- │  CONTROLS (while flying):                            │
-- │   W/A/S/D      – move relative to camera             │
-- │   Space        – ascend                              │
-- │   LeftCtrl     – descend                             │
-- │   Near wall    – auto-slows to 10 st/s (raycast)     │
-- │   Load Pos btn – auto-enables fly, travels at 31     │
-- └──────────────────────────────────────────────────────┘
 
local Players          = game:GetService("Players")
local TweenService     = game:GetService("TweenService")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
 
local LP  = Players.LocalPlayer
local PG  = LP:WaitForChild("PlayerGui")
local Cam = workspace.CurrentCamera
 
-- ============================================================
--  CONFIG
-- ============================================================
local FLY_SPEED    = 60    -- normal manual flight speed (st/s)
local WALL_SPEED   = 10    -- speed when a wall is detected nearby
local TRAVEL_SPEED = 31    -- speed when auto-flying to saved position
local WALL_DIST    = 2.5   -- raycast range for wall detection (studs)
local ARRIVE_DIST  = 2.0   -- distance at which we count as "arrived"
 
-- ============================================================
--  STATE
-- ============================================================
local flyEnabled = false
local flyConn    = nil   -- Heartbeat connection
local noclipConn = nil   -- Stepped connection
local savedPos   = nil   -- Vector3  — position saved by the user
local traveling  = false -- true while auto-flying to savedPos
 
-- ============================================================
--  HELPERS
-- ============================================================
local function getChar() return LP.Character end
local function getHRP()
    local c = getChar(); return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c = getChar(); return c and c:FindFirstChildOfClass("Humanoid")
end
 
-- 8-direction horizontal raycasts to detect nearby walls
local WALL_DIRS = {
    Vector3.new( 1,   0,  0),
    Vector3.new(-1,   0,  0),
    Vector3.new( 0,   0,  1),
    Vector3.new( 0,   0, -1),
    Vector3.new( 0.707, 0,  0.707),
    Vector3.new(-0.707, 0,  0.707),
    Vector3.new( 0.707, 0, -0.707),
    Vector3.new(-0.707, 0, -0.707),
}
 
local function isNearWall()
    local hrp = getHRP(); if not hrp then return false end
    local rp  = RaycastParams.new()
    rp.FilterDescendantsInstances = {getChar()}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    for _, dir in ipairs(WALL_DIRS) do
        if workspace:Raycast(hrp.Position, dir * WALL_DIST, rp) then
            return true
        end
    end
    return false
end
 
