do
    local drag, dStart, pStart = false, nil, nil
    tbar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            drag = true; dStart = inp.Position; pStart = panel.Position
        end
    end)
    tbar.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - dStart
            panel.Position = UDim2.new(pStart.X.Scale, pStart.X.Offset + d.X,
                                        pStart.Y.Scale, pStart.Y.Offset + d.Y)
        end
    end)
end

-- ============================================================
--  STATUS HELPER
-- ============================================================
local DOT_COLS = {
    idle    = Color3.fromRGB(55,  55,  75),
    flying  = Color3.fromRGB(80, 205, 115),
    wall    = Color3.fromRGB(255, 185,  55),
    travel  = Color3.fromRGB(90, 140, 255),
    arrived = Color3.fromRGB(255,  90, 185),
    error   = Color3.fromRGB(220,  65,  75),
}
function setStatus(text, state)
    statusLbl.Text = text
    TweenService:Create(dot, TweenInfo.new(0.2),
        { BackgroundColor3 = DOT_COLS[state or "idle"] }):Play()
end

-- ============================================================
--  BUTTON CALLBACKS
-- ============================================================

-- Fly toggle
flyBtn.MouseButton1Click:Connect(function()
    flyEnabled = not flyEnabled
    if flyEnabled then
        traveling = false; spinning = false; spinTimer = 0
        startFly()
        flyBtn.Text = "🔮  Fly: ON"
        TweenService:Create(flyBtn, TweenInfo.new(0.2),
            { BackgroundColor3 = Color3.fromRGB(160, 60, 200) }):Play()
        setStatus("Flying  •  manual", "flying")
    else
        stopFly()
    end
end)

-- Save position
saveBtn.MouseButton1Click:Connect(function()
    local hrp = getHRP(); if not hrp then return end
    savedPos = hrp.Position
    local txt = ("Saved: %.0f, %.0f, %.0f"):format(savedPos.X, savedPos.Y, savedPos.Z)
    setStatus(txt, flyEnabled and "flying" or "idle")

    TweenService:Create(saveBtn, TweenInfo.new(0.1),
        { BackgroundColor3 = Color3.fromRGB(75, 220, 135) }):Play()
    task.delay(0.35, function()
        TweenService:Create(saveBtn, TweenInfo.new(0.25),
            { BackgroundColor3 = Color3.fromRGB(38, 115, 82) }):Play()
    end)
end)

-- Load position → auto-travel
loadBtn.MouseButton1Click:Connect(function()
    if not savedPos then
        setStatus("Save a position first!", "error")
        -- Shake the button
        local orig = loadBtn.Position
        for i = 1, 6 do
            task.delay(i * 0.055, function()
                loadBtn.Position = orig + UDim2.new(0, i%2==0 and 5 or -5, 0, 0)
            end)
        end
        task.delay(0.40, function() loadBtn.Position = orig end)
        task.delay(1.8,  function()
            setStatus(flyEnabled and "Flying  •  manual" or "No position saved",
                      flyEnabled and "flying" or "idle")
        end)
        return
    end

    -- Enable fly if it isn't already on
    if not flyEnabled then
        flyEnabled = true
        spinning = false; spinTimer = 0
        startFly()
        flyBtn.Text = "🔮  Fly: ON"
        TweenService:Create(flyBtn, TweenInfo.new(0.2),
            { BackgroundColor3 = Color3.fromRGB(160, 60, 200) }):Play()
    end

    -- Start traveling
    spinning  = false
    spinTimer = 0
    traveling = true
    setStatus("Traveling...", "travel")

    TweenService:Create(loadBtn, TweenInfo.new(0.1),
        { BackgroundColor3 = Color3.fromRGB(120, 90, 220) }):Play()
    task.delay(0.35, function()
        TweenService:Create(loadBtn, TweenInfo.new(0.25),
            { BackgroundColor3 = Color3.fromRGB(76, 50, 162) }):Play()
    end)
end)

-- ============================================================
--  RESPAWN CLEANUP
-- ============================================================
LP.CharacterAdded:Connect(function()
    flyEnabled = false
    traveling  = false
    spinning   = false
    spinTimer  = 0
    if flyConn    then flyConn:Disconnect();    flyConn    = nil end
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end

    flyBtn.Text = "🔮  Fly: OFF"
    TweenService:Create(flyBtn, TweenInfo.new(0.2),
        { BackgroundColor3 = Color3.fromRGB(52, 52, 80) }):Play()
    setStatus(savedPos
        and ("Saved: %.0f, %.0f, %.0f"):format(savedPos.X, savedPos.Y, savedPos.Z)
        or  "No position saved", "idle")
end)
