-- ┌─────────────────────────────────────────────────────┐
-- │  Fly  •  Save/Load Position                         │
-- │  LocalScript → StarterPlayerScripts                 │
-- │                                                     │
-- │  CONTROLS (while flying):                           │
-- │   W/A/S/D        – move relative to camera          │
-- │   Space          – ascend                           │
-- │   LeftCtrl       – descend                          │
-- │   Near wall      – auto-slows to 10 st/s            │
-- │   Load Position  – auto-flies → spins → stops fly   │
-- └─────────────────────────────────────────────────────┘

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local LP  = Players.LocalPlayer
local PG  = LP:WaitForChild("PlayerGui")
local Cam = workspace.CurrentCamera

-- ============================================================
--  CONFIG
-- ============================================================
local FLY_SPEED    = 31    -- normal fly speed (st/s)
local WALL_SPEED   = 10    -- near-wall speed (st/s)
local WALL_DIST    = 3.0   -- raycast range for wall detection
local ARRIVE_DIST  = 1.5   -- arrival snap distance
local SPIN_SPEED   = 25    -- radians per second during spin
local SPIN_TIME    = 3.0   -- seconds to spin on arrival

-- ============================================================
--  STATE
-- ============================================================
local flyEnabled  = false
local flyConn     = nil
local noclipConn  = nil
local savedPos    = nil

local traveling   = false
local spinning    = false
local spinTimer   = 0

-- ============================================================
--  HELPERS
-- ============================================================
local function getChar() return LP.Character end
local function getHRP()
    local c = getChar(); return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c = getChar(); return c and c:FindFirstChildOfClass("Humanoid")
end

-- 8-direction wall detection
local WALL_DIRS = {
    Vector3.new( 1, 0,  0), Vector3.new(-1, 0,  0),
    Vector3.new( 0, 0,  1), Vector3.new( 0, 0, -1),
    Vector3.new( 0.707, 0,  0.707), Vector3.new(-0.707, 0,  0.707),
    Vector3.new( 0.707, 0, -0.707), Vector3.new(-0.707, 0, -0.707),
}
local function isNearWall()
    local hrp = getHRP(); if not hrp then return false end
    local rp  = RaycastParams.new()
    rp.FilterDescendantsInstances = { getChar() }
    rp.FilterType = Enum.RaycastFilterType.Exclude
    for _, d in ipairs(WALL_DIRS) do
        if workspace:Raycast(hrp.Position, d * WALL_DIST, rp) then return true end
    end
    return false
end

-- ============================================================
--  SPHERE APPEARANCE
-- ============================================================
local function applySphere()
    local char = getChar(); if not char then return end
    local hrp  = getHRP();  if not hrp  then return end

    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 1
        end
    end

    local sphere        = Instance.new("Part")
    sphere.Name         = "FlySphere"
    sphere.Shape        = Enum.PartType.Ball
    sphere.Size         = Vector3.new(4.5, 4.5, 4.5)
    sphere.Material     = Enum.Material.Neon
    sphere.Color        = Color3.fromRGB(255, 72, 182)
    sphere.CanCollide   = false
    sphere.CastShadow   = false
    sphere.CFrame       = hrp.CFrame
    sphere.Parent       = char

    local weld  = Instance.new("WeldConstraint")
    weld.Part0  = hrp
    weld.Part1  = sphere
    weld.Parent = sphere
end

local function removeSphere()
    local char = getChar(); if not char then return end
    local s = char:FindFirstChild("FlySphere"); if s then s:Destroy() end
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 0
        end
    end
end

-- ============================================================
--  FLY ENGINE
-- ============================================================
local function startFly()
    local hrp = getHRP(); if not hrp then return end
    local hum = getHum(); if hum then hum.PlatformStand = true end

    applySphere()

    -- Body movers
    local bv       = Instance.new("BodyVelocity")
    bv.Name        = "FlyBV"
    bv.MaxForce    = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity    = Vector3.zero
    bv.Parent      = hrp

    local bg       = Instance.new("BodyGyro")
    bg.Name        = "FlyBG"
    bg.MaxTorque   = Vector3.new(1e9, 1e9, 1e9)
    bg.D           = 80
    bg.CFrame      = hrp.CFrame
    bg.Parent      = hrp

    -- NoClip
    noclipConn = RunService.Stepped:Connect(function()
        local c = getChar(); if not c then return end
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)

    -- Main loop
    flyConn = RunService.Heartbeat:Connect(function(dt)
        local hrp2 = getHRP(); if not hrp2 then return end
        local bv2  = hrp2:FindFirstChild("FlyBV"); if not bv2 then return end
        local bg2  = hrp2:FindFirstChild("FlyBG"); if not bg2 then return end

        -- ── SPIN phase ────────────────────────────────────────
        if spinning then
            spinTimer += dt
            bv2.Velocity = Vector3.zero

            -- All three axes spinning as fast as possible
            local t = spinTimer * SPIN_SPEED
            bg2.CFrame = CFrame.new(hrp2.Position)
                * CFrame.fromEulerAnglesXYZ(t * 1.0, t * 1.3, t * 0.7)

            if spinTimer >= SPIN_TIME then
                -- Done spinning → stop fly entirely
                spinning = false
                spinTimer = 0
                flyEnabled = false
                stopFly()   -- defined below, hoisted via upvalue pattern
            else
                setStatus(("Spinning  •  %.1fs left"):format(SPIN_TIME - spinTimer), "arrived")
            end
            return
        end

        -- ── AUTO-TRAVEL ───────────────────────────────────────
        if traveling and savedPos then
            local diff = savedPos - hrp2.Position
            local dist = diff.Magnitude

            if dist <= ARRIVE_DIST then
                traveling = false
                bv2.Velocity = Vector3.zero
                spinning  = true
                spinTimer = 0
                setStatus("Arrived! Spinning...", "arrived")
                return
            end

            bv2.Velocity = diff.Unit * FLY_SPEED
            bg2.CFrame   = CFrame.lookAt(hrp2.Position, hrp2.Position + diff)
            setStatus(("Traveling  •  %.0f st"):format(dist), "travel")
            return
        end

        -- ── MANUAL FLY ────────────────────────────────────────
        local nearWall = isNearWall()
        local speed    = nearWall and WALL_SPEED or FLY_SPEED

        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += Cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= Cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= Cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += Cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then dir += Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then dir -= Vector3.yAxis end

        bv2.Velocity = dir.Magnitude > 0 and dir.Unit * speed or bv2.Velocity * 0.82
        bg2.CFrame   = Cam.CFrame

        setStatus(nearWall and ("Near wall  •  %d st/s"):format(WALL_SPEED)
                             or "Flying  •  manual", nearWall and "wall" or "flying")
    end)
end

function stopFly()
    if flyConn    then flyConn:Disconnect();    flyConn    = nil end
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end

    local hrp = getHRP()
    if hrp then
        local bv = hrp:FindFirstChild("FlyBV"); if bv then bv:Destroy() end
        local bg = hrp:FindFirstChild("FlyBG"); if bg then bg:Destroy() end
    end

    removeSphere()

    local hum = getHum(); if hum then hum.PlatformStand = false end

    traveling = false
    spinning  = false
    spinTimer = 0

    -- Update button visuals
    flyBtn.Text = "🔮  Fly: OFF"
    TweenService:Create(flyBtn, TweenInfo.new(0.2),
        { BackgroundColor3 = Color3.fromRGB(52, 52, 80) }):Play()
    setStatus(savedPos
        and ("Saved: %.0f, %.0f, %.0f"):format(savedPos.X, savedPos.Y, savedPos.Z)
        or  "No position saved", "idle")
end

