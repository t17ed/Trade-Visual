-- ============================================================
--  STATUS HELPER
-- ============================================================
local DOT_COLORS = {
    idle    = Color3.fromRGB(55,  55,  75),
    flying  = Color3.fromRGB(80, 205, 115),
    wall    = Color3.fromRGB(255, 185,  55),
    travel  = Color3.fromRGB(90, 140, 255),
    arrived = Color3.fromRGB(80, 205, 115),
    error   = Color3.fromRGB(220,  65,  75),
}
 
local function setStatus(text, state)
    statusLbl.Text = text
    TweenService:Create(dot, TweenInfo.new(0.2),
        {BackgroundColor3 = DOT_COLORS[state or "idle"]}):Play()
end
 
local function savedPosText()
    if savedPos then
        return ("Saved: %.0f, %.0f, %.0f"):format(savedPos.X, savedPos.Y, savedPos.Z)
    end
    return "No position saved"
end
 
-- ============================================================
--  FLY ENGINE
-- ============================================================
local function startFly()
    local hrp = getHRP(); if not hrp then return end
    local hum = getHum(); if hum then hum.PlatformStand = true end
 
    -- Attach BodyMover instances
    local bv      = Instance.new("BodyVelocity")
    bv.Name       = "FlyBV"
    bv.MaxForce   = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity   = Vector3.zero
    bv.Parent     = hrp
 
    local bg      = Instance.new("BodyGyro")
    bg.Name       = "FlyBG"
    bg.MaxTorque  = Vector3.new(1e9, 1e9, 1e9)
    bg.D          = 100
    bg.CFrame     = hrp.CFrame
    bg.Parent     = hrp
 
    -- NoClip: disable CanCollide on all character parts every physics step
    noclipConn = RunService.Stepped:Connect(function()
        local c = getChar(); if not c then return end
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)
 
    -- Main flight loop (runs every Heartbeat frame)
    flyConn = RunService.Heartbeat:Connect(function()
        local hrp2 = getHRP(); if not hrp2 then return end
        local bv2  = hrp2:FindFirstChild("FlyBV")
        local bg2  = hrp2:FindFirstChild("FlyBG")
        if not bv2 or not bg2 then return end
 
        -- ────── AUTO-TRAVEL MODE ──────────────────────────
        if traveling and savedPos then
            local diff = savedPos - hrp2.Position
            local dist = diff.Magnitude
 
            if dist <= ARRIVE_DIST then
                -- ✓ Arrived at the saved position
                traveling      = false
                bv2.Velocity   = Vector3.zero
 
                setStatus("Arrived! ✓", "arrived")
                TweenService:Create(flyBtn, TweenInfo.new(0.3),
                    {BackgroundColor3 = Color3.fromRGB(55,155,100)}):Play()
 
                -- After 2 s, revert fly button to normal "ON" color
                task.delay(2, function()
                    if flyEnabled then
                        TweenService:Create(flyBtn, TweenInfo.new(0.3),
                            {BackgroundColor3 = Color3.fromRGB(80,100,220)}):Play()
                        setStatus("Flying  •  manual", "flying")
                    end
                end)
                return
            end
 
            -- Move straight toward saved position at exactly TRAVEL_SPEED
            bv2.Velocity = diff.Unit * TRAVEL_SPEED
            bg2.CFrame   = CFrame.lookAt(hrp2.Position, hrp2.Position + diff)
 
            setStatus(("Traveling  •  %.1f st away"):format(dist), "travel")
 
        -- ────── MANUAL FLY MODE ──────────────────────────
        else
            local nearWall = isNearWall()
            local speed    = nearWall and WALL_SPEED or FLY_SPEED
 
            -- Build movement direction from held keys
            local dir = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                dir += Cam.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                dir -= Cam.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                dir -= Cam.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                dir += Cam.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                dir += Vector3.yAxis
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                dir -= Vector3.yAxis
            end
 
            if dir.Magnitude > 0 then
                bv2.Velocity = dir.Unit * speed
            else
                -- Smooth hover-stop (multiply each frame until ~zero)
                bv2.Velocity = bv2.Velocity * 0.80
            end
 
            -- Gyro follows camera orientation
            bg2.CFrame = Cam.CFrame
 
            -- Update status dot and label
            if nearWall then
                setStatus(("Near wall  •  %d st/s"):format(WALL_SPEED), "wall")
            else
                setStatus("Flying  •  manual", "flying")
            end
        end
    end)
end
 
local function stopFly()
    if flyConn    then flyConn:Disconnect();    flyConn    = nil end
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
 
    local hrp = getHRP()
    if hrp then
        local bv = hrp:FindFirstChild("FlyBV"); if bv then bv:Destroy() end
        local bg = hrp:FindFirstChild("FlyBG"); if bg then bg:Destroy() end
    end
 
    local hum = getHum()
    if hum then hum.PlatformStand = false end
 
    traveling = false
    setStatus(savedPosText(), "idle")
end
 
-- ============================================================
--  BUTTON CALLBACKS
-- ============================================================
 
-- ── Fly toggle ───────────────────────────────────────────────
flyBtn.MouseButton1Click:Connect(function()
    flyEnabled = not flyEnabled
    if flyEnabled then
        startFly()
        flyBtn.Text = "🚀  Fly: ON"
        TweenService:Create(flyBtn, TweenInfo.new(0.2),
            {BackgroundColor3 = Color3.fromRGB(80,100,220)}):Play()
    else
        stopFly()
        flyBtn.Text = "🚀  Fly: OFF"
        TweenService:Create(flyBtn, TweenInfo.new(0.2),
            {BackgroundColor3 = Color3.fromRGB(52,52,80)}):Play()
    end
end)
 
-- ── Save position ────────────────────────────────────────────
saveBtn.MouseButton1Click:Connect(function()
    local hrp = getHRP(); if not hrp then return end
    savedPos = hrp.Position
    setStatus(savedPosText(), flyEnabled and "flying" or "idle")
 
    -- Green flash on the save button to confirm
    TweenService:Create(saveBtn, TweenInfo.new(0.1),
        {BackgroundColor3 = Color3.fromRGB(75,220,135)}):Play()
    task.delay(0.3, function()
        TweenService:Create(saveBtn, TweenInfo.new(0.25),
            {BackgroundColor3 = Color3.fromRGB(38,115,82)}):Play()
    end)
end)
 
-- ── Load position  (auto-enables fly, travels at TRAVEL_SPEED)
loadBtn.MouseButton1Click:Connect(function()
    -- Nothing saved yet — shake the button and show error
    if not savedPos then
        setStatus("Save a position first!", "error")
        local orig = loadBtn.Position
        for i = 1, 6 do
            task.delay(i * 0.055, function()
                loadBtn.Position = orig + UDim2.new(0, i%2==0 and 5 or -5, 0, 0)
            end)
        end
        task.delay(0.38, function()
            loadBtn.Position = orig
            task.delay(1.5, function()
                setStatus(savedPosText(), flyEnabled and "flying" or "idle")
            end)
        end)
        return
    end
 
    -- Auto-enable fly if it's currently off
    if not flyEnabled then
        flyEnabled = true
        startFly()
        flyBtn.Text = "🚀  Fly: ON"
        TweenService:Create(flyBtn, TweenInfo.new(0.2),
            {BackgroundColor3 = Color3.fromRGB(80,100,220)}):Play()
    end
 
    -- Begin auto-travel
    traveling = true
 
    -- Bright flash on load button
    TweenService:Create(loadBtn, TweenInfo.new(0.1),
        {BackgroundColor3 = Color3.fromRGB(130,100,230)}):Play()
    task.delay(0.3, function()
        TweenService:Create(loadBtn, TweenInfo.new(0.25),
            {BackgroundColor3 = Color3.fromRGB(76,50,162)}):Play()
    end)
end)
 
-- ============================================================
--  CLEANUP ON RESPAWN
-- ============================================================
LP.CharacterAdded:Connect(function()
    -- Reset fly state after respawn (savedPos is kept intentionally)
    flyEnabled = false
    traveling  = false
    if flyConn    then flyConn:Disconnect();    flyConn    = nil end
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
 
    flyBtn.Text = "🚀  Fly: OFF"
    TweenService:Create(flyBtn, TweenInfo.new(0.2),
        {BackgroundColor3 = Color3.fromRGB(52,52,80)}):Play()
    setStatus(savedPosText(), "idle")
end)
