-- ┌───────────────────────────────────────────────────────────┐
-- │  Fly  •  Save/Load  •  Sphere  •  Ghost  •  Spin Launch   │
-- │  LocalScript  →  StarterPlayerScripts                     │
-- │                                                           │
-- │  CONTROLS (while flying):                                 │
-- │   W/A/S/D        – move relative to camera               │
-- │   Space          – ascend                                 │
-- │   LeftCtrl       – descend                                │
-- │   Near wall      – auto-slows to 10 st/s                  │
-- │   Fly ON         – launch 60 studs up, turn into sphere,  │
-- │                    ghost spawns at launch point           │
-- │   Load Position  – fly at 31 st/s → spin on arrival       │
-- └───────────────────────────────────────────────────────────┘

local Players          = game:GetService("Players")
local TweenService     = game:GetService("TweenService")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LP  = Players.LocalPlayer
local PG  = LP:WaitForChild("PlayerGui")
local Cam = workspace.CurrentCamera

-- ============================================================
--  CONFIG
-- ============================================================
local FLY_SPEED        = 60     -- normal manual flight (st/s)
local WALL_SPEED       = 10     -- near-wall speed
local TRAVEL_SPEED     = 31     -- auto-travel to saved pos
local WALL_DIST        = 2.5    -- raycast range for wall detection
local ARRIVE_DIST      = 2.0    -- snap distance to count as arrived
local LAUNCH_SPEED     = 130    -- upward launch speed on fly enable
local LAUNCH_STUDS     = 60     -- how far to launch upward
local SPIN_DURATION    = 3.2    -- seconds to spin on arrival
local GHOST_ALPHA      = 0.58   -- ghost transparency

-- ============================================================
--  STATE
-- ============================================================
local flyEnabled  = false
local flyConn     = nil
local noclipConn  = nil
local savedPos    = nil      -- Vector3 saved by Save button

-- sub-states (all reset when fly is toggled off)
local traveling   = false
local launching   = false
local launchTimer = 0
local spinning    = false
local spinTime    = 0

-- ghost
local ghostData   = nil   -- { model, hrp, lbl }
local ghostDistConn = nil

-- ============================================================
--  HELPERS
-- ============================================================
local function getChar() return LP.Character end
local function getHRP()
    local c = getChar(); return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c = getChar(); return c and c:FindFirstChildOfClass("Humanoid")
end

-- 8-direction horizontal raycasts to detect nearby walls
local WALL_DIRS = {
    Vector3.new( 1, 0,  0), Vector3.new(-1, 0,  0),
    Vector3.new( 0, 0,  1), Vector3.new( 0, 0, -1),
    Vector3.new( 0.707, 0,  0.707), Vector3.new(-0.707, 0,  0.707),
    Vector3.new( 0.707, 0, -0.707), Vector3.new(-0.707, 0, -0.707),
}
local function isNearWall()
    local hrp = getHRP(); if not hrp then return false end
    local rp  = RaycastParams.new()
    rp.FilterDescendantsInstances = {getChar()}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    for _, dir in ipairs(WALL_DIRS) do
        if workspace:Raycast(hrp.Position, dir * WALL_DIST, rp) then return true end
    end
    return false
end

-- ============================================================
--  APPEARANCE — pink neon sphere
-- ============================================================
local function applySphere()
    local char = getChar(); if not char then return end
    local hrp  = getHRP();  if not hrp  then return end

    -- Hide every visible part / face
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Transparency = 1
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 1
        end
    end

    -- Build neon pink sphere
    local sphere       = Instance.new("Part")
    sphere.Name        = "FlySphere"
    sphere.Shape       = Enum.PartType.Ball
    sphere.Size        = Vector3.new(4.5, 4.5, 4.5)
    sphere.Material    = Enum.Material.Neon
    sphere.Color       = Color3.fromRGB(255, 72, 182)   -- hot pink
    sphere.CanCollide  = false
    sphere.CastShadow  = false
    sphere.CFrame      = hrp.CFrame
    sphere.Parent      = char

    -- Weld to HRP so it follows the character
    local weld  = Instance.new("WeldConstraint")
    weld.Part0  = hrp
    weld.Part1  = sphere
    weld.Parent = sphere
end

local function removeSphere()
    local char = getChar(); if not char then return end

    local sphere = char:FindFirstChild("FlySphere")
    if sphere then sphere:Destroy() end

    -- Restore all part visibility
    for _, obj in ipairs(char:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Transparency = 0
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = 0
        end
    end
end

-- ============================================================
--  GHOST — transparent clone at launch point
-- ============================================================
local function removeGhost()
    if ghostDistConn then ghostDistConn:Disconnect(); ghostDistConn = nil end
    if ghostData then ghostData.model:Destroy(); ghostData = nil end
end

--  Call this BEFORE applySphere so the clone looks like the real player
local function createGhost()
    removeGhost()

    local char = getChar(); if not char then return end
    local hrp  = getHRP();  if not hrp  then return end
    local launchCF = hrp.CFrame   -- snapshot where fly was pressed

    -- ── Clone the character ─────────────────────────────────
    local ghost = char:Clone()
    ghost.Name  = "c00l_Ghost"

    -- Strip scripts, animators, body movers from the clone
    for _, obj in ipairs(ghost:GetDescendants()) do
        if obj:IsA("Script") or obj:IsA("LocalScript") or obj:IsA("ModuleScript") then
            obj:Destroy()
        elseif obj:IsA("Animator") or obj:IsA("AnimationController") then
            obj:Destroy()
        elseif obj:IsA("BodyVelocity") or obj:IsA("BodyGyro")
            or obj:IsA("BodyPosition") or obj:IsA("BodyForce") then
            obj:Destroy()
        elseif obj:IsA("BillboardGui") then
            -- remove existing name tags so we can add our own
            obj:Destroy()
        end
    end

    -- Make every part transparent & anchored in place
    for _, obj in ipairs(ghost:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Transparency = GHOST_ALPHA
            obj.Anchored     = true
            obj.CanCollide   = false
            obj.CastShadow   = false
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = GHOST_ALPHA
        end
    end

    -- Remove any sphere we accidentally cloned
    local ghostSphere = ghost:FindFirstChild("FlySphere")
    if ghostSphere then ghostSphere:Destroy() end

    -- Position the ghost's HRP where fly was pressed
    local ghostHRP = ghost:FindFirstChild("HumanoidRootPart")
    if ghostHRP then
        ghostHRP.CFrame = launchCF
    end

    -- ── Distance BillboardGui ───────────────────────────────
    if ghostHRP then
        local billboard = Instance.new("BillboardGui")
        billboard.Size           = UDim2.new(0, 155, 0, 34)
        billboard.StudsOffset    = Vector3.new(0, 5.5, 0)
        billboard.AlwaysOnTop    = true
        billboard.LightInfluence = 0
        billboard.Parent         = ghostHRP

        -- Pill-shaped background
        local bg = Instance.new("Frame")
        bg.Size                = UDim2.new(1, 0, 1, 0)
        bg.BackgroundColor3    = Color3.fromRGB(0, 0, 0)
        bg.BackgroundTransparency = 0.42
        bg.BorderSizePixel     = 0
        bg.Parent              = billboard
        Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

        -- Distance text
        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3            = Color3.fromRGB(255, 170, 220)  -- pink
        lbl.Font                  = Enum.Font.GothamBold
        lbl.TextSize              = 14
        lbl.TextStrokeTransparency = 0.4
        lbl.TextStrokeColor3      = Color3.new(0, 0, 0)
        lbl.Text                  = "0 studs away"
        lbl.Parent                = bg

        ghostData = { model = ghost, hrp = ghostHRP, lbl = lbl }
    end

    ghost.Parent = workspace

    -- Live distance update
    ghostDistConn = RunService.Heartbeat:Connect(function()
        local playerHRP = getHRP()
        if not playerHRP or not ghostData then return end
        local dist = math.floor((playerHRP.Position - ghostData.hrp.Position).Magnitude + 0.5)
        ghostData.lbl.Text = dist .. " studs away"
    end)
end

-- ============================================================
--  FLY ENGINE
-- ============================================================
local function startFly()
    local hrp = getHRP(); if not hrp then return end
    local hum = getHum(); if hum then hum.PlatformStand = true end

    -- 1. Snapshot the character BEFORE transforming it
    createGhost()

    -- 2. Turn into pink neon sphere
    applySphere()

    -- 3. Attach BodyMover instances
    local bv     = Instance.new("BodyVelocity")
    bv.Name      = "FlyBV"
    bv.MaxForce  = Vector3.new(1e9, 1e9, 1e9)
    bv.Velocity  = Vector3.zero
    bv.Parent    = hrp

    local bg     = Instance.new("BodyGyro")
    bg.Name      = "FlyBG"
    bg.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bg.D         = 100
    bg.CFrame    = hrp.CFrame
    bg.Parent    = hrp

    -- 4. NoClip: disable CanCollide every physics step
    noclipConn = RunService.Stepped:Connect(function()
        local c = getChar(); if not c then return end
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = false end
        end
    end)

    -- 5. Begin the upward launch
    launching   = true
    launchTimer = 0
    spinning    = false
    spinTime    = 0

    -- 6. Main flight loop (Heartbeat gives us dt)
    flyConn = RunService.Heartbeat:Connect(function(dt)
        local hrp2 = getHRP(); if not hrp2 then return end
        local bv2  = hrp2:FindFirstChild("FlyBV")
        local bg2  = hrp2:FindFirstChild("FlyBG")
        if not bv2 or not bg2 then return end

        -- ── LAUNCH phase: shoot upward LAUNCH_STUDS ──────────
        if launching then
            launchTimer += dt
            bv2.Velocity = Vector3.new(0, LAUNCH_SPEED, 0)
            -- Keep sphere upright during launch
            bg2.CFrame = CFrame.new(hrp2.Position)
            if launchTimer >= (LAUNCH_STUDS / LAUNCH_SPEED) then
                launching = false
                bv2.Velocity = Vector3.zero
                setStatus("Flying  •  manual", "flying")
            else
                setStatus(("Launching  •  %.0f st/s"):format(LAUNCH_SPEED), "travel")
            end
            return
        end

        -- ── SPIN phase: tumble in all directions ──────────────
        if spinning then
            spinTime += dt
            bv2.Velocity = Vector3.zero   -- hover in place while spinning

            -- Three independent rotation speeds on X, Y, Z → looks like tumbling
            local rot = CFrame.fromEulerAnglesXYZ(
                spinTime * 3.2,   -- pitch  (fast forward roll)
                spinTime * 5.0,   -- yaw    (spin around up)
                spinTime * 2.1    -- roll   (sideways tilt)
            )
            bg2.CFrame = CFrame.new(hrp2.Position) * rot

            if spinTime >= SPIN_DURATION then
                spinning  = false
                spinTime  = 0
                -- Snap gyro back to camera-facing orientation
                bg2.CFrame = Cam.CFrame
                setStatus("Flying  •  manual", "flying")
            else
                local pct = math.floor((spinTime / SPIN_DURATION) * 100)
                setStatus(("Spinning  •  %d%%"):format(pct), "arrived")
            end
            return
        end

        -- ── AUTO-TRAVEL: fly toward saved position at 31 st/s ─
        if traveling and savedPos then
            local diff = savedPos - hrp2.Position
            local dist = diff.Magnitude

            if dist <= ARRIVE_DIST then
                -- Arrived! → trigger spin celebration
                traveling = false
                bv2.Velocity = Vector3.zero
                spinning  = true
                spinTime  = 0
                setStatus("Arrived!  •  spinning", "arrived")
                return
            end

            bv2.Velocity = diff.Unit * TRAVEL_SPEED
            bg2.CFrame   = CFrame.lookAt(hrp2.Position, hrp2.Position + diff)
            setStatus(("Traveling  •  %.1f st"):format(dist), "travel")
            return
        end

        -- ── MANUAL FLY ────────────────────────────────────────
        local nearWall = isNearWall()
        local speed    = nearWall and WALL_SPEED or FLY_SPEED

        local dir = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            dir += Cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            dir -= Cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            dir -= Cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            dir += Cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            dir += Vector3.yAxis          end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
            dir -= Vector3.yAxis          end

        bv2.Velocity = dir.Magnitude > 0 and dir.Unit * speed or bv2.Velocity * 0.80
        bg2.CFrame   = Cam.CFrame   -- sphere faces camera direction

        if nearWall then
            setStatus(("Near wall  •  %d st/s"):format(WALL_SPEED), "wall")
        else
            setStatus("Flying  •  manual", "flying")
        end
    end)
end

local function stopFly()
    if flyConn    then flyConn:Disconnect();    flyConn    = nil end
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end

    -- Remove body movers
    local hrp = getHRP()
    if hrp then
        local bv = hrp:FindFirstChild("FlyBV"); if bv then bv:Destroy() end
        local bg = hrp:FindFirstChild("FlyBG"); if bg then bg:Destroy() end
    end

    -- Restore character appearance and physics
    removeSphere()
    removeGhost()

    local hum = getHum()
    if hum then hum.PlatformStand = false end

    -- Reset all sub-states
    traveling   = false
    launching   = false
    launchTimer = 0
    spinning    = false
    spinTime    = 0
end

