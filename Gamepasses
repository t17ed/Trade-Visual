-- =========================================================
-- ADD THIS UNDER THE SCALE CODE ABOVE
-- =========================================================

local function hoverGrow(button,scaleObject)
	button.MouseEnter:Connect(function()
		TweenService:Create(
			scaleObject,
			TweenInfo.new(0.12,Enum.EasingStyle.Quint),
			{
				Scale = 1.08
			}
		):Play()
	end)

	button.MouseLeave:Connect(function()
		TweenService:Create(
			scaleObject,
			TweenInfo.new(0.12,Enum.EasingStyle.Quint),
			{
				Scale = 1
			}
		):Play()
	end)
end

hoverGrow(yesButton,yesScale)
hoverGrow(noButton,noScale)



