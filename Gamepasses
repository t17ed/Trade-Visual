-- HIDE SELECTIONS
local function hideSelections()
	for _,v in ipairs(scrollingFrame:GetChildren()) do
		if v.Name:find("Selection") then
			if v:IsA("GuiObject") then
				v.Visible = false
			end
		end
	end
end

scrollingFrame.ChildAdded:Connect(function()
	task.wait()
	hideSelections()
end)

task.spawn(function()
	while true do
		hideSelections()
		task.wait(0.05)
	end
end)

-- NOTIFICATION
local function showNotification(text,color)
	local clone = notifTemplate:Clone()
	clone.Parent = notificationUI
	clone.Visible = true

	local txt = nil

	if clone:IsA("TextLabel") then
		txt = clone
	else
		txt = clone:FindFirstChild("Text",true)
	end

	if txt then
		txt.RichText = true
		txt.Text = text
		txt.TextColor3 = color
	end

	task.delay(5,function()
		if clone then
			clone:Destroy()
		end
	end)
end

-- RESET COLORS
local function resetPanels()
	for _,panel in ipairs(adminPanels) do
		if panel and panel.Parent then
			local spacer = panel:FindFirstChild("Spacer")

			if spacer then
				spacer.BackgroundColor3 = defaultColor

				local stroke = spacer:FindFirstChildOfClass("UIStroke")
				if stroke then
					stroke.Color = Color3.fromRGB(0,0,0)
				end

				panel:SetAttribute("Clicked",false)
			end
		end
	end
end

-- ACCEPT CHECK
local function connectAcceptWatcher()
	local other = tradeUI:WaitForChild("Other")
	local readyButton = other:WaitForChild("ReadyButton")
	local txt = readyButton:WaitForChild("Txt")

	txt:GetPropertyChangedSignal("Text"):Connect(function()
		if txt.Text == "ACCEPT" then
			resetPanels()
		end
	end)
end

task.spawn(connectAcceptWatcher)

-- TRADE VISIBILITY
tradeUI:GetPropertyChangedSignal("Visible"):Connect(function()
	if tradeUI.Visible then
		resetPanels()
	else
		if not warningTemplate.Visible then
			confirmationUI.Enabled = false
		end
	end
end)

-- CREATE PANEL
local function createAdminPanel()
	local clone = template:Clone()
	clone.Name = "AdminPanel"
	clone.Parent = scrollingFrame
	clone.Visible = true

	local spacer = clone:WaitForChild("Spacer")
	local cash = spacer:WaitForChild("Cash")
	local title = spacer:WaitForChild("Title")

	local stroke = spacer:FindFirstChildOfClass("UIStroke")

	cash.Text = "9,999"
	title.Text = "[🎁] Admin Panel"

	spacer.BackgroundColor3 = defaultColor

	if stroke then
		stroke.Color = Color3.fromRGB(0,0,0)
	end

	clone:SetAttribute("Clicked",false)

	-- IMAGE
	local img = spacer:FindFirstChild("CustomImage")

	if not img then
		img = Instance.new("ImageLabel")
		img.Name = "CustomImage"
		img.Parent = spacer
		img.BackgroundTransparency = 1
		img.Image = "rbxassetid://139291316302932"
		img.Size = UDim2.new(0.5,0,0.5,0)
		img.Position = UDim2.new(0.25,0,0.25,0)
	end

	-- INPUTS
	local holding = false

	spacer.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			holding = true

			if clone:GetAttribute("Clicked") then
				spacer.BackgroundColor3 = holdColor
			end
		end
	end)

	spacer.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			if not holding then
				return
			end

			holding = false

			clickSound:Play()

			if clone:GetAttribute("Clicked") then
				clone:SetAttribute("Clicked",false)

				spacer.BackgroundColor3 = defaultColor

				if stroke then
					stroke.Color = Color3.fromRGB(0,0,0)
				end

				failSound:Play()

				showNotification(
					"Failed to add 'Admin Panel' to trade!",
					Color3.fromRGB(255,0,0)
				)

				return
			end

			pendingPanel = clone

			confirmationUI.Enabled = true
			warningTemplate.Visible = true
		end
	end)

	table.insert(adminPanels,clone)
end

-- DELETE PANELS
local function deleteAdminPanels()
	for _,v in ipairs(adminPanels) do
		if v and v.Parent then
			v:Destroy()
		end
	end

	table.clear(adminPanels)
end

-- YES BUTTON
yesButton.MouseButton1Click:Connect(function()
	warningTemplate.Visible = false
	confirmationUI.Enabled = false

	yesSound:Play()

	if pendingPanel and pendingPanel.Parent then
		local spacer = pendingPanel:FindFirstChild("Spacer")

		if spacer then
			local stroke = spacer:FindFirstChildOfClass("UIStroke")

			spacer.BackgroundColor3 = clickedColor

			if stroke then
				stroke.Color = strokeClickedColor
			end

			pendingPanel:SetAttribute("Clicked",true)
		end
	end

	showNotification(
		"Successfully added 'Admin Panel' to trade!",
		Color3.fromRGB(0,255,0)
	)
end)

