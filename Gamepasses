local function isGreenStyle(panel)
	if not panel then return false end

	local spacer = panel:FindFirstChild("Spacer")
	if not spacer then return false end

	local clicked = panel:GetAttribute("Clicked")
	if clicked then
		return true
	end

	local bg = spacer.BackgroundColor3
	return (bg == clickedColor)
end

local function updateAcceptedVisibility()
	local other = tradeUI:FindFirstChild("Other")
	if not other then return end

	local readyButtonLocal = other:FindFirstChild("ReadyButton")
	if not readyButtonLocal then return end

	local txt = readyButtonLocal:FindFirstChild("Txt")
	if not txt then return end

	if txt.Text == "ACCEPTED" then
		for _, panel in ipairs(adminPanels) do
			if panel then
				panel.Visible = isGreenStyle(panel)
			end
		end
	else
		for _, panel in ipairs(adminPanels) do
			if panel then
				panel.Visible = true
			end
		end
	end
end

task.spawn(function()
	while true do
		pcall(updateAcceptedVisibility)
		task.wait(0.2)
	end
end)

