			local stroke = spacer:FindFirstChildOfClass("UIStroke")
			spacer.BackgroundColor3 = clickedColor
			if stroke then stroke.Color = strokeClickedColor end
			pendingPanel:SetAttribute("Clicked",true)
		end
	end

	showNotification("Successfully added item to trade!", Color3.fromRGB(0,255,0))
end)

