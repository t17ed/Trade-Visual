local function tweenHover(button)

	local scale = Instance.new("UIScale")
	scale.Scale = 1
	scale.Parent = button

	button.MouseEnter:Connect(function()
		TweenService:Create(
			scale,
			TweenInfo.new(0.08,Enum.EasingStyle.Quint),
			{
				Scale = 1.06
			}
		):Play()
	end)

	button.MouseLeave:Connect(function()
		TweenService:Create(
			scale,
			TweenInfo.new(0.08,Enum.EasingStyle.Quint),
			{
				Scale = 1
			}
		):Play()
	end)
end

