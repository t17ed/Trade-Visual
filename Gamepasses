--==================================================--
-- ACCEPTED FILTER (ADDED FEATURE - DO NOT MODIFY BASE CODE)
-- Only show GREEN (clicked) panels when "ACCEPTED"
--==================================================--

local function applyAcceptedFilter(isAccepted)
	for _, panel in ipairs(adminPanels) do
		if panel and panel.Parent then
			local isGreen = panel:GetAttribute("Clicked") == true

			if isAccepted then
				-- Only show green panels
				panel.Visible = isGreen
			else
				-- Show everything again
				panel.Visible = true
			end
		end
	end
end

local function hookAcceptedWatcher()
	local ok, other = pcall(function()
		local gui = playerGui:WaitForChild("TradeLiveTrade")
		local main = gui:WaitForChild("TradeLiveTrade")
		local other = main:WaitForChild("Other")
		return other
	end)

	if not ok or not other then return end

	local readyButton = other:FindFirstChild("ReadyButton")
	if not readyButton then return end

	local txt = readyButton:FindFirstChild("Txt")
	if not txt then return end

	local function update()
		if txt.Text == "ACCEPTED" then
			applyAcceptedFilter(true)
		else
			applyAcceptedFilter(false)
		end
	end

	-- initial state
	update()

	-- react to changes
	txt:GetPropertyChangedSignal("Text"):Connect(update)
end

task.spawn(function()
	while true do
		hookAcceptedWatcher()
		task.wait(1)
	end
end)
