-- GLOBAL NEON TEXT EFFECT (ADDED)
local function applyNeon(inst)
	if inst:IsA("TextLabel") or inst:IsA("TextButton") then
		inst.TextStrokeTransparency = 0.35
		inst.TextStrokeColor3 = neonPink
	end
end

local function scanNeon(root)
	for _,v in ipairs(root:GetDescendants()) do
		applyNeon(v)
	end
end

