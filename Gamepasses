local function getReadyText()
	local ok, txt = pcall(function()
		return playerGui:WaitForChild("TradeLiveTrade")
			:WaitForChild("TradeLiveTrade")
			:WaitForChild("Other")
			:WaitForChild("ReadyButton")
			:WaitForChild("Txt").Text
	end)
	return ok and txt or ""
end

local function updateGreenButtons()
	local txt = getReadyText()
	local shouldShow = (txt ~= "ACCEPT")

	for _,obj in ipairs(scrollingFrame:GetChildren()) do
		if obj:IsA("GuiObject") and obj.Name == "AdminPanel" then
			obj.Visible = shouldShow
		end
	end
end

task.spawn(function()
	while true do
		updateGreenButtons()
		task.wait(0.15)
	end
end)

