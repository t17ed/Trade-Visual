local function showNotification(text,color)

	if notificationCooldown[text] then
		return
	end

	notificationCooldown[text] = true

	task.delay(0.15,function()
		notificationCooldown[text] = nil
	end)

	local clone = notifTemplate:Clone()
	clone.Parent = notificationUI
	clone.Visible = true

	local txt = clone:IsA("TextLabel") and clone or clone:FindFirstChild("Text",true)

	if txt then
		txt.RichText = true
		txt.Text = text
		txt.TextColor3 = color
	end

	local originalPos = clone.Position

	clone.Position = originalPos + UDim2.new(0,300,0,0)

	TweenService:Create(
		clone,
		TweenInfo.new(0.25,Enum.EasingStyle.Quint),
		{
			Position = originalPos
		}
	):Play()

	task.delay(4,function()

		if clone and clone.Parent then

			TweenService:Create(
				clone,
				TweenInfo.new(0.2),
				{
					BackgroundTransparency = 1
				}
			):Play()

			task.wait(0.2)

			if clone then
				clone:Destroy()
			end
		end
	end)
end

local function resetPanels()

	for _,panel in ipairs(adminPanels) do

		if panel and panel.Parent then

			panel.Visible = true

			panel:SetAttribute("Clicked",false)

			local spacer = panel:FindFirstChild("Spacer")

			if spacer then

				spacer.BackgroundColor3 = defaultColor

				local stroke = spacer:FindFirstChildOfClass("UIStroke")

				if stroke then
					stroke.Color = Color3.fromRGB(0,0,0)
				end
			end
		end
	end
end

tradeUI:GetPropertyChangedSignal("Visible"):Connect(function()

	if tradeUI.Visible then

		acceptProcessed = false

		resetPanels()

	else

		if not warningTemplate.Visible then
			confirmationUI.Enabled = false
		end
	end
end)

local function getAcceptState()

	local other = tradeUI:FindFirstChild("Other")
	if not other then
		return false
	end

	local readyButton = other:FindFirstChild("ReadyButton")
	if not readyButton then
		return false
	end

	local txt = readyButton:FindFirstChild("Txt")
	if not txt then
		return false
	end

	return txt.Text == "ACCEPT"
end

local function createAdminPanel(preset)

	local clone = template:Clone()

	clone.Name = "AdminPanel"
	clone.Parent = scrollingFrame
	clone.Visible = true

	local spacer = clone:WaitForChild("Spacer")

	local cash = spacer:WaitForChild("Cash")
	local title = spacer:WaitForChild("Title")

	local stroke = spacer:FindFirstChildOfClass("UIStroke")

	cash.Text = preset.Cash
	title.Text = preset.Title

	spacer.BackgroundColor3 = defaultColor

	if stroke then
		stroke.Color = Color3.fromRGB(0,0,0)
	end

	clone:SetAttribute("Clicked",false)
	clone:SetAttribute("PresetName",preset.Name)

	local img = spacer:FindFirstChild("CustomImage")

	if not img then
		img = Instance.new("ImageLabel")
		img.Name = "CustomImage"
		img.Parent = spacer
		img.BackgroundTransparency = 1
		img.Size = UDim2.new(0.5,0,0.5,0)
		img.Position = UDim2.new(0.25,0,0.25,0)
	end

	img.Image = preset.Image

	spacer.InputBegan:Connect(function(input)

		if input.UserInputType == Enum.UserInputType.MouseButton1 then

			playSound("rbxassetid://75311202481026",1)

			if getAcceptState() then

				if clone:GetAttribute("Clicked") then

					clone:SetAttribute("Clicked",false)

					spacer.BackgroundColor3 = defaultColor

					if stroke then
						stroke.Color = Color3.fromRGB(0,0,0)
					end

					showNotification(
						'Removed "'..preset.Title..'" from trade!',
						Color3.fromRGB(255,0,0)
					)

					playSound("rbxassetid://126210834885859",0.5)
				end

				return
			end

			if clone:GetAttribute("Clicked") then

				clone:SetAttribute("Clicked",false)

				spacer.BackgroundColor3 = defaultColor

				if stroke then
					stroke.Color = Color3.fromRGB(0,0,0)
				end

				showNotification(
					'Removed "'..preset.Title..'" from trade!',
					Color3.fromRGB(255,0,0)
				)

				playSound("rbxassetid://126210834885859",0.5)

				return
			end

			pendingPanel = clone

			confirmationUI.Enabled = true
			warningTemplate.Visible = true
		end
	end)

	table.insert(adminPanels,clone)
end

local function getVisibleCount(name)

	local count = 0

	for _,v in ipairs(adminPanels) do

		if v and v.Parent and v.Visible then

			if v:GetAttribute("PresetName") == name then
				count += 1
			end
		end
	end

	return count
end

local function removePreset(name)

	for i = #adminPanels,1,-1 do

		local panel = adminPanels[i]

		if panel and panel.Parent then

			if panel:GetAttribute("PresetName") == name then

				panel.Visible = false

				break
			end
		end
	end
end

