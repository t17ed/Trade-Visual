		keybindButton.Visible = false

	else

		minimize.Text = "-"

		buttonsHolder.Visible = true
		toggleHolder.Visible = true
		autoText.Visible = true
		website.Visible = true
		speedBox.Visible = true
		keybindButton.Visible = true

		TweenService:Create(
			frame,
			TweenInfo.new(0.25,Enum.EasingStyle.Quint),
			{
				Size = UDim2.new(0,340,0,430)
			}
		):Play()
	end
end)

