		end
	end)
end

task.spawn(connectAcceptWatcher)

-- 🔥 ADDED: ACCEPTED VISIBILITY CONTROLLER
local function updateAcceptedVisibility()
	if not readyTxtRef then return end

	local isAccepted = (readyTxtRef.Text == "ACCEPTED")

	acceptLocked = isAccepted

	for _,panel in ipairs(adminPanels) do
		if panel and panel.Parent then
			local isGreen = panel:GetAttribute("Clicked") == true

			if isAccepted then
				-- ONLY green panels visible
				panel.Visible = isGreen
			else
				-- restore normal behaviour
				panel.Visible = true
			end
		end
	end
end

-- 🔥 ADDED: LIVE WATCHER FOR ACCEPTED STATE
