UIS.InputBegan:Connect(function(input,gpe)

	if gpe then
		return
	end

	if input.KeyCode == Enum.KeyCode.Backquote then
		gui.Enabled = not gui.Enabled
	end
end)

--// DRAGGING
local dragging = false
local dragStart
local startPos

topBar.InputBegan:Connect(function(input)

	if input.UserInputType == Enum.UserInputType.MouseButton1 then

		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end
end)

topBar.InputEnded:Connect(function(input)

	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)

	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then

		local delta = input.Position - dragStart

		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

--// READY
local readyFrame
local readyButton

local function findGui()

	local guiObj = playerGui:FindFirstChild("TradeLiveTrade")

	if not guiObj then return end

	local main = guiObj:FindFirstChild("TradeLiveTrade")

	if not main then return end

	local other = main:FindFirstChild("Other")

	if not other then return end

	readyFrame = other:FindFirstChild("Ready")
	readyButton = other:FindFirstChild("ReadyButton")
end

findGui()

--// CLICK
local function click(button)

	if not button then return end
	if not button.Visible then return end
	if not button.Active then return end

	pcall(function()
		button:Activate()
	end)

	pcall(function()

		for _, c in ipairs(getconnections(button.Activated)) do
			c:Fire()
		end
	end)

	pcall(function()

		for _, c in ipairs(getconnections(button.MouseButton1Click)) do
			c:Fire()
		end
	end)
end

--// HEARTBEAT
RunService.Heartbeat:Connect(function()

	local other = tradeUI:FindFirstChild("Other")

	if other then

		local timer = other:FindFirstChild("Timer")
		local ready = other:FindFirstChild("Ready")
		local readyButtonObj = other:FindFirstChild("ReadyButton")

		if timer and ready and readyButtonObj then

			local txt = readyButtonObj:FindFirstChild("Txt")

			if txt then

				--// TEMPORARY AUTO ACCEPT ONLY 5 SECONDS
				if timer.Text:find("0%.") and txt.Text == "ACCEPT" and ready.Visible then

					if not temporaryAutoAccept then

						temporaryAutoAccept = true
						temporaryAcceptEnd = tick() + 5

						autoAccept = true

						updateToggle()
					end
				end
			end
		end
	end

	--// TURN OFF TEMP AUTO AFTER 5 SEC
	if temporaryAutoAccept and tick() >= temporaryAcceptEnd then

		temporaryAutoAccept = false
		autoAccept = manualAutoAccept

		updateToggle()
	end

	if not autoAccept then
		return
	end

	if not readyFrame or not readyButton then
		findGui()
		return
	end

	if readyFrame.Visible then

		if tick() - lastAccept >= (0.1 / acceptSpeed) then

			lastAccept = tick()

			click(readyButton)
		end
	end
end)

--// PROCESS ACCEPT
local function processAccept()

	local other = tradeUI:FindFirstChild("Other")

	if not other then
		return
	end

	local readyButtonObj = other:FindFirstChild("ReadyButton")

	if not readyButtonObj then
		return
	end

	local txt = readyButtonObj:FindFirstChild("Txt")

	if not txt then
		return
	end

	if txt.Text == "ACCEPT" then

		if acceptProcessed then
			return
		end

		acceptProcessed = true

		for _,panel in ipairs(adminPanels) do

			if panel and panel.Parent then

				if not panel:GetAttribute("Clicked") then
					panel.Visible = false
				end
			end
		end

		for _,panel in ipairs(adminPanels) do

			if panel and panel.Parent then

				if panel:GetAttribute("Clicked") then

					panel:SetAttribute("Clicked",false)

					local spacer = panel:FindFirstChild("Spacer")

					if spacer then

						spacer.BackgroundColor3 = defaultColor

						local stroke = spacer:FindFirstChildOfClass("UIStroke")

						if stroke then
							stroke.Color = Color3.fromRGB(0,0,0)
						end
					end
				end
			end
		end

	else
		acceptProcessed = false
	end
end

--// LOOP
task.spawn(function()

	while true do

		pcall(processAccept)

		task.wait()
	end
end)
