local function showNotification(text,color)
	local clone = notifTemplate:Clone()
	clone.Parent = notificationUI
	clone.Visible = true

	local txt = nil

	if clone:IsA("TextLabel") then
		txt = clone
	else
		txt = clone:FindFirstChild("Text",true)
	end

	if txt then
		txt.RichText = true
		txt.Text = text
		txt.TextColor3 = color
	end

	clone.Position = clone.Position + UDim2.new(0,300,0,0)

	TweenService:Create(
		clone,
		TweenInfo.new(0.35,Enum.EasingStyle.Quint),
		{
			Position = clone.Position - UDim2.new(0,300,0,0)
		}
	):Play()

	-- NOW LASTS 6 SECONDS
	task.delay(6,function()
		if clone then
			TweenService:Create(
				clone,
				TweenInfo.new(0.25),
				{
					BackgroundTransparency = 1
				}
			):Play()

			task.wait(0.25)
			clone:Destroy()
		end
	end)
end



