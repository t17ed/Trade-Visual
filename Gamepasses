UIS.InputBegan:Connect(function(input,gpe)

	if gpe then
		return
	end

	if keybindListening then

		if input.KeyCode ~= Enum.KeyCode.Unknown then

			keybindListening = false

			keybind = input.KeyCode

			keybindButton.Text = keybind.Name

			pcall(function()

				if writefile then
					writefile("t17ed_keybind.txt",keybind.Name)
				end
			end)

			showNotification(
				"Keybind set to "..keybind.Name,
				Color3.fromRGB(0,255,0)
			)
		end

		return
	end

	if input.KeyCode == keybind then

		manualAutoAccept = not manualAutoAccept
		autoAccept = manualAutoAccept or temporaryAutoAccept

		updateToggle()
	end
end)

