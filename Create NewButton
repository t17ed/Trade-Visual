-- Studio-only press: simulates a real click on the local button. No effect in a live game.
local function pressButton(btn)
	if not btn or not btn:IsA("GuiObject") or not btn.Visible then return end
	local inset = GuiService:GetGuiInset()
	local center = btn.AbsolutePosition + btn.AbsoluteSize / 2
	VirtualInputManager:SendMouseButtonEvent(center.X + inset.X, center.Y + inset.Y, 0, true, game, 0)
	VirtualInputManager:SendMouseButtonEvent(center.X + inset.X, center.Y + inset.Y, 0, false, game, 0)
end

local function playSound(id, volume)
	local s = Instance.new("Sound")
	s.SoundId = id
	s.Volume = volume or 1
	s.Parent = playerGui
	s:Play()
	Debris:AddItem(s, 5)
end

local function neonText(obj)
	if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
		local old = obj:FindFirstChild("Glow")
		if old then old:Destroy() end
		local glow = Instance.new("UIStroke")
		glow.Name = "Glow"
		glow.Color = Color3.fromRGB(255, 20, 147)
		glow.Thickness = 2
		glow.Parent = obj
	end
end

