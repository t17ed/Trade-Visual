		else
			TweenService:Create(toggleCircle, TweenInfo.new(0.18, Enum.EasingStyle.Quint),
				{ Position = UDim2.new(0, 3, 0.5, -11), BackgroundColor3 = Color3.new(1, 1, 1) }):Play()
		end
	end
	toggleHolder.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			manualAutoAccept = not manualAutoAccept
			autoAccept = manualAutoAccept or temporaryAutoAccept
			updateToggle()
		end
	end)

	local speedBox = Instance.new("TextBox")
	speedBox.Parent = frame
	speedBox.Size = UDim2.new(0, 160, 0, 34)
	speedBox.Position = UDim2.new(0.5, -80, 1, -92)
	speedBox.BackgroundColor3 = Color3.fromRGB(45, 20, 40)
	speedBox.TextColor3 = Color3.new(1, 1, 1)
	speedBox.PlaceholderText = "25..."; speedBox.Text = "25..."
	speedBox.Font = Enum.Font.GothamBold; speedBox.TextSize = 15
	speedBox.ClearTextOnFocus = false
	do local cc = Instance.new("UICorner"); cc.CornerRadius = UDim.new(0, 10); cc.Parent = speedBox end
	neonText(speedBox)
	speedBox.FocusLost:Connect(function()
		local num = tonumber((speedBox.Text:gsub("%D", ""))) or 25
		num = math.clamp(num, 25, 500)
		acceptSpeed = num
		speedBox.Text = tostring(num) .. "..."
	end)

	local keybindButton = Instance.new("TextButton")
	keybindButton.Parent = frame
	keybindButton.Size = UDim2.new(0, 34, 0, 34)
	keybindButton.Position = UDim2.new(0.5, 90, 1, -92)
	keybindButton.BackgroundColor3 = neonPink
	keybindButton.Text = keybind.Name; keybindButton.Font = Enum.Font.GothamBlack; keybindButton.TextSize = 12
	keybindButton.TextColor3 = Color3.new(1, 1, 1)
	do local cc = Instance.new("UICorner"); cc.CornerRadius = UDim.new(1, 0); cc.Parent = keybindButton end
	neonText(keybindButton)
	keybindButton.MouseButton1Click:Connect(function()
		keybindListening = true
		keybindButton.Text = "..."
		showNotification("Press any key...", Color3.fromRGB(255, 255, 0))
	end)

	local website = Instance.new("TextButton")
	website.Parent = frame
	website.Size = UDim2.new(1, 0, 0, 24)
	website.Position = UDim2.new(0, 0, 1, -28)
	website.BackgroundTransparency = 1
	website.Text = "t17ed.github.io"; website.Font = Enum.Font.GothamBlack; website.TextSize = 15
	website.TextColor3 = softPink
	neonText(website)
	website.MouseButton1Click:Connect(function() showNotification("t17ed.github.io", Color3.fromRGB(255, 255, 0)) end)

	local minimized = false
	minimize.MouseButton1Click:Connect(function()
		minimized = not minimized
		minimize.Text = minimized and "+" or "-"
		buttonsHolder.Visible = not minimized
		toggleHolder.Visible = not minimized
		autoText.Visible = not minimized
		website.Visible = not minimized
		speedBox.Visible = not minimized
		keybindButton.Visible = not minimized
		TweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
			Size = minimized and UDim2.new(0, 340, 0, 45) or UDim2.new(0, 340, 0, 430),
		}):Play()
	end)

	--// INPUTS: keybind capture, auto-accept hotkey, and ] menu toggle
	UIS.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if keybindListening then
			if input.KeyCode ~= Enum.KeyCode.Unknown then
				keybindListening = false
				keybind = input.KeyCode
				keybindButton.Text = keybind.Name
				showNotification("Keybind set to " .. keybind.Name, Color3.fromRGB(0, 255, 0))
			end
			return
		end
		if input.KeyCode == Enum.KeyCode.RightBracket then
			gui.Enabled = not gui.Enabled
		elseif input.KeyCode == keybind then
			manualAutoAccept = not manualAutoAccept
			autoAccept = manualAutoAccept or temporaryAutoAccept
			updateToggle()
		end
	end)

	--// DRAGGING
	local dragging, dragStart, startPos = false, nil, nil
	topBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true; dragStart = input.Position; startPos = frame.Position
		end
	end)
	topBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	--// AUTO ACCEPT (Studio-only press)
	RunService.Heartbeat:Connect(function()
		local other = tradeUI and tradeUI:FindFirstChild("Other")
		if other then
			local timer = other:FindFirstChild("Timer")
			local ready = other:FindFirstChild("Ready")
			local rbObj = other:FindFirstChild("ReadyButton")
			local txt = rbObj and rbObj:FindFirstChild("Txt")
			if timer and ready and txt and timer.Text == "⏰0.1s Left" and txt.Text == "ACCEPT" and ready.Visible then
				if not temporaryAutoAccept then
					temporaryAutoAccept = true
					temporaryAcceptEnd = tick() + 5
					autoAccept = true
					updateToggle()
				end
			end
		end
		if temporaryAutoAccept and tick() >= temporaryAcceptEnd then
			temporaryAutoAccept = false
			autoAccept = manualAutoAccept
			updateToggle()
		end
		if not autoAccept then return end
		if other then
			local ready = other:FindFirstChild("Ready")
			local rbObj = other:FindFirstChild("ReadyButton")
			local txt = rbObj and rbObj:FindFirstChild("Txt")
			if ready and txt and ready.Visible and txt.Text == "ACCEPT" then
				if tick() - lastAccept >= (1 / acceptSpeed) then
					lastAccept = tick()
					pressButton(rbObj)
				end
			end
		end
	end)

	--// PROCESS ACCEPT (clean up panels once accepted)
	local function processAccept()
		local other = tradeUI and tradeUI:FindFirstChild("Other")
		local rbObj = other and other:FindFirstChild("ReadyButton")
		local txt = rbObj and rbObj:FindFirstChild("Txt")
		if not txt then return end
		if txt.Text == "ACCEPT" then
			if acceptProcessed then return end
			acceptProcessed = true
			for _, panel in ipairs(adminPanels) do
				if panel and panel.Parent and not panel:GetAttribute("Clicked") then panel.Visible = false end
			end
			for _, panel in ipairs(adminPanels) do
				if panel and panel.Parent and panel:GetAttribute("Clicked") then
					panel:SetAttribute("Clicked", false)
					local spacer = panel:FindFirstChild("Spacer")
					if spacer then
						spacer.BackgroundColor3 = defaultColor
						local stroke = spacer:FindFirstChildOfClass("UIStroke")
						if stroke then stroke.Color = Color3.fromRGB(0, 0, 0) end
					end
				end
			end
		else
			acceptProcessed = false
		end
	end
	task.spawn(function() while true do pcall(processAccept); task.wait() end end)
end

--====================================================================
-- GAMEPASSES BUTTON MANAGER
--====================================================================
local function getInner()
	local screen = playerGui:FindFirstChild("TradeLiveTrade")
	return screen and screen:FindFirstChild("TradeLiveTrade")
end

local function placeClone(clone, sibling)
	if clone.Parent:FindFirstChildWhichIsA("UIGridStyleLayout") then
		clone.LayoutOrder = sibling.LayoutOrder + 1
		return
	end
	local stepY = sibling.AbsoluteSize.Y
	if stepY <= 0 then stepY = sibling.Size.Y.Offset end
	local p = sibling.Position
	clone.Position = UDim2.new(p.X.Scale, p.X.Offset, p.Y.Scale, p.Y.Offset + stepY + 6)
end

local curInner, curSide, curGamepass, curOrigColor
local siblingOrig = {}

-- Select (green) or deselect the Gamepasses tab. Never touches the spawner menu.
local function setActive(state)
	if not (curGamepass and curGamepass.Parent and curSide) then return end
	gamepassActive = state
	if state then
		curGamepass.BackgroundColor3 = GREEN_COLOR
		for _, c in ipairs(curSide:GetChildren()) do
			if c ~= curGamepass and c:IsA("GuiObject") then
				if siblingOrig[c] == nil then siblingOrig[c] = c.BackgroundColor3 end
				c.BackgroundColor3 = SIBLING_COLOR
			end
		end
		if not spawnerStarted then startSpawner() end
		if SpawnerAPI then SpawnerAPI.setPanelsVisible(true) end
	else
		if curOrigColor then curGamepass.BackgroundColor3 = curOrigColor end
		for c, orig in pairs(siblingOrig) do
			if c and c.Parent then c.BackgroundColor3 = orig end
		end
		if SpawnerAPI then SpawnerAPI.setPanelsVisible(false) end
	end
end

local function wireButton(gamepasses)
	if gamepasses:GetAttribute("GP_Wired") then return end
	gamepasses:SetAttribute("GP_Wired", true)

	local uiScale = gamepasses:FindFirstChildOfClass("UIScale")
	if not uiScale then
		uiScale = Instance.new("UIScale")
		uiScale.Scale = 1
		uiScale.Parent = gamepasses
	end

	local activeTween, hovering = nil, false
	local function tweenScale(target, duration, onComplete)
		if activeTween then activeTween:Cancel() end
		local tw = TweenService:Create(uiScale, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Scale = target })
		activeTween = tw
		if onComplete then
			tw.Completed:Connect(function(stateEnum)
				if stateEnum == Enum.PlaybackState.Completed then onComplete() end
			end)
		end
		tw:Play()
	end

	gamepasses.MouseEnter:Connect(function() hovering = true; tweenScale(HOVER_SCALE, TWEEN_TIME) end)
	gamepasses.MouseLeave:Connect(function() hovering = false; tweenScale(1, TWEEN_TIME) end)

	local function onClick()
		local half = math.max(TWEEN_TIME * 0.5, 0.03)
		tweenScale(1, half, function() if hovering then tweenScale(HOVER_SCALE, half) end end)
		setActive(not gamepassActive)
	end

	if gamepasses:IsA("GuiButton") then
		gamepasses.MouseButton1Click:Connect(onClick)
	else
		gamepasses.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then onClick() end
		end)
	end
end

-- Clicking any other side button deselects Gamepasses and hides created panels
local function wireSiblings(sideButtons, gamepasses)
	for _, c in ipairs(sideButtons:GetChildren()) do
		if c ~= gamepasses and c:IsA("GuiObject") and not c:GetAttribute("GP_SibWired") then
			c:SetAttribute("GP_SibWired", true)
			c.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					if gamepassActive then setActive(false) end
				end
			end)
		end
	end
end

local function ensureButton()
	local inner = getInner()
	if not inner then return end
	local sideButtons = inner:FindFirstChild("Side Buttons")
	local brainrots = sideButtons and sideButtons:FindFirstChild("Brainrots")
	if not (sideButtons and brainrots) then return end

	local created = false
	local gamepasses = sideButtons:FindFirstChild("Gamepasses")
	if not gamepasses then
		gamepasses = brainrots:Clone()
		gamepasses.Name = "Gamepasses"
		gamepasses.Parent = sideButtons
		placeClone(gamepasses, brainrots)
		-- Make sure it does NOT start in the selected/green look (Brainrots may be the active tab)
		local unselected = brainrots.BackgroundColor3
		if colorsClose(unselected, GREEN_COLOR) then
			for _, c in ipairs(sideButtons:GetChildren()) do
				if c ~= gamepasses and c ~= brainrots and c:IsA("GuiObject") and not colorsClose(c.BackgroundColor3, GREEN_COLOR) then
					unselected = c.BackgroundColor3
					break
				end
			end
		end
		gamepasses.BackgroundColor3 = unselected
		created = true
	end
	gamepasses.Visible = true

	local txt = gamepasses:FindFirstChild("Txt")
	if txt and (txt:IsA("TextLabel") or txt:IsA("TextButton") or txt:IsA("TextBox")) then
		txt.Visible = true
		txt.Text = "GPs"
	end

	curInner, curSide, curGamepass = inner, sideButtons, gamepasses
	if created then
		curOrigColor = gamepasses.BackgroundColor3
	elseif curOrigColor == nil then
		curOrigColor = gamepasses.BackgroundColor3
	end

	wireButton(gamepasses)
	wireSiblings(sideButtons, gamepasses)

	if not spawnerStarted then startSpawner() end

	-- Restore the selected state instantly if it was active before a rebuild
	if gamepassActive then setActive(true) end
end

local function hookInner(inner)
	if inner:GetAttribute("GP_Hooked") then return end
	inner:SetAttribute("GP_Hooked", true)
	ensureButton()
	inner:GetPropertyChangedSignal("Visible"):Connect(ensureButton)
	local side = inner:FindFirstChild("Side Buttons")
	if side then
		side.ChildRemoved:Connect(function(child)
			if child.Name == "Gamepasses" then task.defer(ensureButton) end
		end)
	end
	inner.DescendantAdded:Connect(function(d)
		if d.Name == "Brainrots" or d.Name == "Side Buttons" then ensureButton() end
	end)
end

local function hookScreen(screen)
	local inner = screen:FindFirstChild("TradeLiveTrade")
	if inner then hookInner(inner) end
	screen.ChildAdded:Connect(function(c)
		if c.Name == "TradeLiveTrade" then hookInner(c) end
	end)
end

local existingScreen = playerGui:FindFirstChild("TradeLiveTrade")
if existingScreen then hookScreen(existingScreen) end
playerGui.ChildAdded:Connect(function(c)
	if c.Name == "TradeLiveTrade" then hookScreen(c) end
end)
