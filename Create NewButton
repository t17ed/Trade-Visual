local function createAdminPanel(preset)
    local clone = template:Clone()
    clone.Name = "AdminPanel"
    clone.Parent = scrollingFrame

    spawnCount += 1
    clone.LayoutOrder = spawnCount
    clone.Visible = gearsIsColour(SHOW_COLOR)   -- only when gears is green

    local spacer = clone:WaitForChild("Spacer")
    local cash   = spacer:WaitForChild("Cash")
    local title  = spacer:WaitForChild("Title")
    local stroke = spacer:FindFirstChildOfClass("UIStroke")

    cash.Text  = preset.Cash
    title.Text = preset.Title
    spacer.BackgroundColor3 = defaultColor
    if stroke then stroke.Color = Color3.fromRGB(0,0,0) end

    clone:SetAttribute("Clicked", false)
    clone:SetAttribute("PresetName", preset.Name)

    local img = spacer:FindFirstChild("CustomImage")
    if not img then
        img = Instance.new("ImageLabel")
        img.Name = "CustomImage"
        img.BackgroundTransparency = 1
        img.Size = UDim2.new(0.5,0,0.5,0)
        img.Position = UDim2.new(0.25,0,0.25,0)
        img.Parent = spacer
    end
    img.Image = preset.Image

    spacer.InputBegan:Connect(function(input)
        if acceptLocked then return end          -- locked once trade hits ACCEPT
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            playSound("rbxassetid://75311202481026", 1)
            if clone:GetAttribute("Clicked") then
                clone:SetAttribute("Clicked", false)
                spacer.BackgroundColor3 = defaultColor
                if stroke then stroke.Color = Color3.fromRGB(0,0,0) end
                showNotification('Removed "'..preset.Title..'" from trade!', Color3.fromRGB(255,0,0))
                playSound("rbxassetid://126210834885859", 0.5)
                return
            end
            pendingPanel = clone
            confirmationUI.Enabled = true
            warningTemplate.Visible = true
        end
    end)

    table.insert(adminPanels, clone)
    refreshCards()
end

local function getVisibleCount(name)
    local count = 0
    for _, v in ipairs(adminPanels) do
        if v and v.Parent and not removedPresets[v] and v:GetAttribute("PresetName") == name then
            count += 1
        end
    end
    return count
end

local function removePreset(name)
    for i = #adminPanels, 1, -1 do
        local panel = adminPanels[i]
        if panel and panel.Parent and panel:GetAttribute("PresetName") == name and not removedPresets[panel] then
            removedPresets[panel] = true
            panel.Visible = false
            showNotification('Removed "'..name..'" preset!', Color3.fromRGB(255,0,0))
            break
        end
    end
end

