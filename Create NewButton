-- Self-contained notifications -------------------------------------------------
local notifGui
local notificationCooldown = {}
local function showNotification(text, color)
	if notificationCooldown[text] then return end
	notificationCooldown[text] = true
	task.delay(0.15, function() notificationCooldown[text] = nil end)

	if not (notifGui and notifGui.Parent) then
		notifGui = Instance.new("ScreenGui")
		notifGui.Name = "GP_Notifications"
		notifGui.ResetOnSpawn = false
		notifGui.DisplayOrder = 1000000
		notifGui.Parent = playerGui
		local list = Instance.new("UIListLayout")
		list.Padding = UDim.new(0, 6)
		list.VerticalAlignment = Enum.VerticalAlignment.Bottom
		list.HorizontalAlignment = Enum.HorizontalAlignment.Right
		list.SortOrder = Enum.SortOrder.LayoutOrder
		list.Parent = notifGui
		local pad = Instance.new("UIPadding")
		pad.PaddingRight = UDim.new(0, 12)
		pad.PaddingBottom = UDim.new(0, 12)
		pad.Parent = notifGui
	end

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 270, 0, 34)
	label.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
	label.BackgroundTransparency = 1
	label.TextTransparency = 1
	label.TextColor3 = color or Color3.new(1, 1, 1)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 14
	label.RichText = true
	label.Text = text
	label.Parent = notifGui
	local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 8); c.Parent = label

	TweenService:Create(label, TweenInfo.new(0.2), { BackgroundTransparency = 0.1, TextTransparency = 0 }):Play()
	task.delay(4, function()
		if label and label.Parent then
			TweenService:Create(label, TweenInfo.new(0.25), { BackgroundTransparency = 1, TextTransparency = 1 }):Play()
			task.wait(0.3)
			if label then label:Destroy() end
		end
	end)
end

