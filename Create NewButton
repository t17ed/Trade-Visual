	speedBox.Font = Enum.Font.GothamBold
	speedBox.TextSize = 15
	speedBox.ClearTextOnFocus = false
	do local cc = Instance.new("UICorner"); cc.CornerRadius = UDim.new(0, 10); cc.Parent = speedBox end
	neonText(speedBox)
	speedBox.FocusLost:Connect(function()
		local num = tonumber((speedBox.Text:gsub("%D", ""))) or 25
		num = math.clamp(num, 25, 500)
		acceptSpeed = num
		speedBox.Text = tostring(num) .. "..."
	end)

	local keybindButton = Instance.new("TextButton")
	keybindButton.Parent = frame
	keybindButton.Size = UDim2.new(0, 34, 0, 34)
	keybindButton.Position = UDim2.new(0.5, 90, 1, -92)
	keybindButton.BackgroundColor3 = neonPink
	keybindButton.Text = keybind.Name
	keybindButton.Font = Enum.Font.GothamBlack
	keybindButton.TextSize = 12
	keybindButton.TextColor3 = Color3.new(1, 1, 1)
	do local cc = Instance.new("UICorner"); cc.CornerRadius = UDim.new(1, 0); cc.Parent = keybindButton end
	neonText(keybindButton)
	keybindButton.MouseButton1Click:Connect(function()
		keybindListening = true
		keybindButton.Text = "..."
		showNotification("Press any key...", Color3.fromRGB(255, 255, 0))
	end)

	local website = Instance.new("TextButton")
	website.Parent = frame
	website.Size = UDim2.new(1, 0, 0, 24)
	website.Position = UDim2.new(0, 0, 1, -28)
	website.BackgroundTransparency = 1
	website.Text = "t17ed.github.io"
	website.Font = Enum.Font.GothamBlack
	website.TextSize = 15
	website.TextColor3 = softPink
	neonText(website)
	website.MouseButton1Click:Connect(function()
		showNotification("t17ed.github.io", Color3.fromRGB(255, 255, 0))
	end)

	--// MINIMIZE
	local minimized = false
	minimize.MouseButton1Click:Connect(function()
		minimized = not minimized
		minimize.Text = minimized and "+" or "-"
		buttonsHolder.Visible = not minimized
		toggleHolder.Visible = not minimized
		autoText.Visible = not minimized
		website.Visible = not minimized
		speedBox.Visible = not minimized
		keybindButton.Visible = not minimized
		TweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {
			Size = minimized and UDim2.new(0, 340, 0, 45) or UDim2.new(0, 340, 0, 430),
		}):Play()
	end)

	--// INPUTS (keybind capture + toggle)
	UIS.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if keybindListening then
			if input.KeyCode ~= Enum.KeyCode.Unknown then
				keybindListening = false
				keybind = input.KeyCode
				keybindButton.Text = keybind.Name
				showNotification("Keybind set to " .. keybind.Name, Color3.fromRGB(0, 255, 0))
			end
			return
		end
		if input.KeyCode == keybind then
			manualAutoAccept = not manualAutoAccept
			autoAccept = manualAutoAccept or temporaryAutoAccept
			updateToggle()
		elseif input.KeyCode == Enum.KeyCode.Backquote then
			gui.Enabled = not gui.Enabled
		end
	end)

	--// DRAGGING
	local dragging, dragStart, startPos = false, nil, nil
	topBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position
		end
	end)
	topBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	UIS.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = input.Position - dragStart
			frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)

	--// AUTO ACCEPT LOOP (only while green; Studio-only press)
	RunService.Heartbeat:Connect(function()
		if not isActive() then return end
		local other = tradeUI:FindFirstChild("Other")
		if other then
			local timer = other:FindFirstChild("Timer")
			local ready = other:FindFirstChild("Ready")
			local readyButtonObj = other:FindFirstChild("ReadyButton")
			local txt = readyButtonObj and readyButtonObj:FindFirstChild("Txt")
			if timer and ready and txt and timer.Text == "⏰0.1s Left" and txt.Text == "ACCEPT" and ready.Visible then
				if not temporaryAutoAccept then
					temporaryAutoAccept = true
					temporaryAcceptEnd = tick() + 5
					autoAccept = true
					updateToggle()
				end
			end
		end
		if temporaryAutoAccept and tick() >= temporaryAcceptEnd then
			temporaryAutoAccept = false
			autoAccept = manualAutoAccept
			updateToggle()
		end
		if not autoAccept then return end
		if other then
			local ready = other:FindFirstChild("Ready")
			local readyButtonObj = other:FindFirstChild("ReadyButton")
			local txt = readyButtonObj and readyButtonObj:FindFirstChild("Txt")
			if ready and txt and ready.Visible and txt.Text == "ACCEPT" then
				if tick() - lastAccept >= (1 / acceptSpeed) then
					lastAccept = tick()
					pressButton(readyButtonObj)
				end
			end
		end
	end)

	--// PROCESS ACCEPT (hide unselected panels once accepted)
	local function processAccept()
		local other = tradeUI:FindFirstChild("Other")
		local readyButtonObj = other and other:FindFirstChild("ReadyButton")
		local txt = readyButtonObj and readyButtonObj:FindFirstChild("Txt")
		if not txt then return end
		if txt.Text == "ACCEPT" then
			if acceptProcessed then return end
			acceptProcessed = true
			for _, panel in ipairs(adminPanels) do
				if panel and panel.Parent and not panel:GetAttribute("Clicked") then
					panel.Visible = false
				end
			end
			for _, panel in ipairs(adminPanels) do
				if panel and panel.Parent and panel:GetAttribute("Clicked") then
					panel:SetAttribute("Clicked", false)
					local spacer = panel:FindFirstChild("Spacer")
					if spacer then
						spacer.BackgroundColor3 = defaultColor
						local stroke = spacer:FindFirstChildOfClass("UIStroke")
						if stroke then stroke.Color = Color3.fromRGB(0, 0, 0) end
					end
				end
			end
		else
			acceptProcessed = false
		end
	end
	task.spawn(function()
		while true do
			if isActive() then pcall(processAccept) end
			task.wait()
		end
	end)

	--// OPTIONAL: rename a Settings label if your game has one (only while green)
	task.spawn(function()
		local connected = false
		while true do
			if isActive() then
				pcall(function()
					local functionText = playerGui:FindFirstChild("Settings")
					functionText = functionText and functionText:FindFirstChild("Settings")
					functionText = functionText and functionText:FindFirstChild("Content")
					functionText = functionText and functionText:FindFirstChild("ScrollingFrame")
					functionText = functionText and functionText:FindFirstChild("VFX")
					functionText = functionText and functionText:FindFirstChild("Function")
					if functionText then
						functionText.Text = "Gamepass Trading"
						if not connected then
							connected = true
							functionText:GetPropertyChangedSignal("Text"):Connect(function()
								if isActive() and functionText.Text ~= "Gamepass Trading" then
									functionText.Text = "Gamepass Trading"
								end
							end)
						end
					end
				end)
			end
			task.wait(0.2)
		end
	end)
end

