local function colorsClose(a, b)
	return math.abs(a.R - b.R) < 0.02 and math.abs(a.G - b.G) < 0.02 and math.abs(a.B - b.B) < 0.02
end

-- Self-contained confirmation popup (neutral wording) --------------------------
local function askConfirm(itemTitle, onYes, onNo)
	local gui = Instance.new("ScreenGui")
	gui.Name = "GP_Confirm"
	gui.ResetOnSpawn = false
	gui.DisplayOrder = 1000001
	gui.Parent = playerGui

	local dim = Instance.new("TextButton")
	dim.Text = ""
	dim.AutoButtonColor = false
	dim.Size = UDim2.new(1, 0, 1, 0)
	dim.BackgroundColor3 = Color3.new(0, 0, 0)
	dim.BackgroundTransparency = 0.5
	dim.Parent = gui

	local box = Instance.new("Frame")
	box.Size = UDim2.new(0, 320, 0, 170)
	box.Position = UDim2.new(0.5, -160, 0.5, -85)
	box.BackgroundColor3 = Color3.fromRGB(24, 24, 30)
	box.Parent = gui
	do local cc = Instance.new("UICorner"); cc.CornerRadius = UDim.new(0, 12); cc.Parent = box end

	local title = Instance.new("TextLabel")
	title.BackgroundTransparency = 1
	title.Position = UDim2.new(0, 16, 0, 14)
	title.Size = UDim2.new(1, -32, 0, 22)
	title.Font = Enum.Font.GothamBlack
	title.TextSize = 18
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.TextColor3 = Color3.new(1, 1, 1)
	title.Text = "Add item to trade"
	title.Parent = box

	local desc = Instance.new("TextLabel")
	desc.BackgroundTransparency = 1
	desc.Position = UDim2.new(0, 16, 0, 44)
	desc.Size = UDim2.new(1, -32, 0, 70)
	desc.Font = Enum.Font.Gotham
	desc.TextSize = 14
	desc.TextWrapped = true
	desc.TextYAlignment = Enum.TextYAlignment.Top
	desc.TextXAlignment = Enum.TextXAlignment.Left
	desc.TextColor3 = Color3.fromRGB(210, 210, 210)
	desc.Text = "Add " .. tostring(itemTitle) .. " to the trade?"
	desc.Parent = box

	local function mkBtn(txt, x, col)
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(0, 140, 0, 36)
		b.Position = UDim2.new(0, x, 1, -50)
		b.BackgroundColor3 = col
		b.Text = txt
		b.Font = Enum.Font.GothamBold
		b.TextSize = 15
		b.TextColor3 = Color3.new(1, 1, 1)
		b.Parent = box
		local cc = Instance.new("UICorner"); cc.CornerRadius = UDim.new(0, 8); cc.Parent = b
		return b
	end

	local yes = mkBtn("Yes", 16, GREEN_COLOR)
	local no  = mkBtn("No", 164, Color3.fromRGB(170, 60, 70))
	local function close() if gui then gui:Destroy() end end
	yes.MouseButton1Click:Connect(function() close(); if onYes then onYes() end end)
	no.MouseButton1Click:Connect(function() close(); if onNo then onNo() end end)
	dim.MouseButton1Click:Connect(function() close(); if onNo then onNo() end end)
end

-- Studio-only press: simulates a real click on the local button. No effect in a live game.
local function pressButton(btn)
	if not btn or not btn:IsA("GuiObject") or not btn.Visible then return end
	local inset = GuiService:GetGuiInset()
	local center = btn.AbsolutePosition + btn.AbsoluteSize / 2
	VirtualInputManager:SendMouseButtonEvent(center.X + inset.X, center.Y + inset.Y, 0, true, game, 0)
	VirtualInputManager:SendMouseButtonEvent(center.X + inset.X, center.Y + inset.Y, 0, false, game, 0)
end

local function playSound(id, volume)
	local s = Instance.new("Sound")
	s.SoundId = id
	s.Volume = volume or 1
	s.Parent = playerGui
	s:Play()
	Debris:AddItem(s, 5)
end

local function neonText(obj)
	if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
		local old = obj:FindFirstChild("Glow")
		if old then old:Destroy() end
		local glow = Instance.new("UIStroke")
		glow.Name = "Glow"
		glow.Color = Color3.fromRGB(255, 20, 147)
		glow.Thickness = 2
		glow.Parent = obj
	end
end

--====================================================================
-- SPAWNER (built once the trade UI exists; menu stays visible, ] toggles it)
--====================================================================
local function startSpawner()
	if spawnerStarted then return end
	spawnerStarted = true

	--// TRADE UI (your game's UI) -- essentials checked before yielding
	local tradeRoot = playerGui:FindFirstChild("TradeLiveTrade")
	local tradeUI = tradeRoot and tradeRoot:FindFirstChild("TradeLiveTrade")
	local yourFrame = tradeUI and tradeUI:FindFirstChild("Your")
	local scrollingFrame = yourFrame and yourFrame:FindFirstChild("ScrollingFrame")
	if not scrollingFrame then warn("[Spawner] Your.ScrollingFrame not found; cannot start"); spawnerStarted = false; return end
	local template = scrollingFrame:FindFirstChild("Template")
	if template then template.Visible = false else warn("[Spawner] ScrollingFrame.Template not found; preset spawning disabled") end

	--// ORIGINAL RICH-TEXT NOTIFICATIONS (uses your game's Notification UI)
	local notificationCooldown = {}
	local notificationRoot = playerGui:WaitForChild("Notification", 5)
	local notificationUI   = notificationRoot and notificationRoot:WaitForChild("Notification", 5)
	local notifTemplate    = notificationUI and notificationUI:WaitForChild("Template", 5)
	if not notifTemplate then warn("[Spawner] Notification template not found; using a simple fallback") end

	local fallbackGui
	local function showNotification(text, color)
		if notificationCooldown[text] then return end
		notificationCooldown[text] = true
		task.delay(0.15, function() notificationCooldown[text] = nil end)

		if notifTemplate then
			local clone = notifTemplate:Clone()
			clone.Parent = notificationUI
			clone.Visible = true
			local txt = clone:IsA("TextLabel") and clone or clone:FindFirstChild("Text", true)
			if txt then
				txt.RichText = true
				txt.Text = text
				txt.TextColor3 = color
			end
			local originalPos = clone.Position
			clone.Position = originalPos + UDim2.new(0, 300, 0, 0)
			TweenService:Create(clone, TweenInfo.new(0.25, Enum.EasingStyle.Quint), { Position = originalPos }):Play()
			task.delay(4, function()
				if clone and clone.Parent then
					TweenService:Create(clone, TweenInfo.new(0.2), { BackgroundTransparency = 1 }):Play()
					task.wait(0.2)
					if clone then clone:Destroy() end
				end
			end)
			return
		end

		-- fallback (RichText kept) if the game has no Notification template
		if not (fallbackGui and fallbackGui.Parent) then
			fallbackGui = Instance.new("ScreenGui")
			fallbackGui.Name = "GP_Notifications"
			fallbackGui.ResetOnSpawn = false
			fallbackGui.DisplayOrder = 1000000
			fallbackGui.Parent = playerGui
			local list = Instance.new("UIListLayout")
			list.Padding = UDim.new(0, 6)
			list.VerticalAlignment = Enum.VerticalAlignment.Bottom
			list.HorizontalAlignment = Enum.HorizontalAlignment.Right
			list.Parent = fallbackGui
			local pad = Instance.new("UIPadding")
			pad.PaddingRight = UDim.new(0, 12); pad.PaddingBottom = UDim.new(0, 12); pad.Parent = fallbackGui
		end
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(0, 270, 0, 34)
		label.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
		label.TextColor3 = color or Color3.new(1, 1, 1)
		label.Font = Enum.Font.GothamBold
		label.TextSize = 14
		label.RichText = true
		label.Text = text
		label.Parent = fallbackGui
		local cc = Instance.new("UICorner"); cc.CornerRadius = UDim.new(0, 8); cc.Parent = label
		task.delay(4, function() if label then label:Destroy() end end)
	end

