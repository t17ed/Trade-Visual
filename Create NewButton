local function getInner()
	local screen = playerGui:FindFirstChild("TradeLiveTrade")
	return screen and screen:FindFirstChild("TradeLiveTrade")
end

-- Stack the clone below Brainrots (or order it after, if a UI layout is used)
local function placeClone(clone, sibling)
	if clone.Parent:FindFirstChildWhichIsA("UIGridStyleLayout") then
		clone.LayoutOrder = sibling.LayoutOrder + 1
		return
	end
	local stepY = sibling.AbsoluteSize.Y
	if stepY <= 0 then stepY = sibling.Size.Y.Offset end
	local p = sibling.Position
	clone.Position = UDim2.new(p.X.Scale, p.X.Offset, p.Y.Scale, p.Y.Offset + stepY + 6)
end

local function clearYourList(inner)
	local your = inner:FindFirstChild("Your")
	local sf = your and your:FindFirstChild("ScrollingFrame")
	if not sf then warn("[Gamepasses] ScrollingFrame missing; nothing cleared"); return end
	local ok, err = pcall(function()
		for _, child in ipairs(sf:GetChildren()) do
			if child.Name ~= "Template" and not child:IsA("UIGridLayout") then
				child:Destroy()
			end
		end
	end)
	if not ok then warn("[Gamepasses] Failed clearing ScrollingFrame: " .. tostring(err)) end
end

local curInner, curSide, curGamepass, curOrigColor
local siblingOrig = {}

local function setActive(state)
	if not (curGamepass and curGamepass.Parent and curSide) then return end
	gamepassActive = state
	if state then
		curGamepass.BackgroundColor3 = GREEN_COLOR
		for _, c in ipairs(curSide:GetChildren()) do
			if c ~= curGamepass and c:IsA("GuiObject") then
				if siblingOrig[c] == nil then siblingOrig[c] = c.BackgroundColor3 end
				c.BackgroundColor3 = SIBLING_COLOR
			end
		end
		clearYourList(curInner)
		if not spawnerStarted then startSpawner() end
		setSpawnerShown(true)
	else
		if curOrigColor then curGamepass.BackgroundColor3 = curOrigColor end
		for c, orig in pairs(siblingOrig) do
			if c and c.Parent then c.BackgroundColor3 = orig end
		end
		setSpawnerShown(false)
	end
end

local function wireButton(gamepasses)
	if gamepasses:GetAttribute("GP_Wired") then return end
	gamepasses:SetAttribute("GP_Wired", true)

	local uiScale = gamepasses:FindFirstChildOfClass("UIScale")
	if not uiScale then
		uiScale = Instance.new("UIScale")
		uiScale.Scale = 1
		uiScale.Parent = gamepasses
	end

	local activeTween, hovering = nil, false
	local function tweenScale(target, duration, onComplete)
		if activeTween then activeTween:Cancel() end
		local tw = TweenService:Create(uiScale, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Scale = target })
		activeTween = tw
		if onComplete then
			tw.Completed:Connect(function(stateEnum)
				if stateEnum == Enum.PlaybackState.Completed then onComplete() end
			end)
		end
		tw:Play()
	end

	gamepasses.MouseEnter:Connect(function()
		hovering = true
		tweenScale(HOVER_SCALE, TWEEN_TIME)
	end)
	gamepasses.MouseLeave:Connect(function()
		hovering = false
		tweenScale(1, TWEEN_TIME)
	end)

	local function onClick()
		local half = math.max(TWEEN_TIME * 0.5, 0.03)
		tweenScale(1, half, function()
			if hovering then tweenScale(HOVER_SCALE, half) end
		end)
		setActive(not gamepassActive)
	end

	if gamepasses:IsA("GuiButton") then
		gamepasses.MouseButton1Click:Connect(onClick)
	else
		gamepasses.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				onClick()
			end
		end)
	end
end

-- Builds the button if missing; safe to call repeatedly (synchronous, no double-clone)
local function ensureButton()
	local inner = getInner()
	if not inner then return end
	local sideButtons = inner:FindFirstChild("Side Buttons")
	local brainrots = sideButtons and sideButtons:FindFirstChild("Brainrots")
	if not (sideButtons and brainrots) then return end

	local gamepasses = sideButtons:FindFirstChild("Gamepasses")
	if not gamepasses then
		gamepasses = brainrots:Clone()
		gamepasses.Name = "Gamepasses"
		gamepasses.Parent = sideButtons
		placeClone(gamepasses, brainrots)
	end
	gamepasses.Visible = true

	local txt = gamepasses:FindFirstChild("Txt")
	if txt and (txt:IsA("TextLabel") or txt:IsA("TextButton") or txt:IsA("TextBox")) then
		txt.Visible = true
		txt.Text = "Gamepasses"
	end

	curInner, curSide, curGamepass = inner, sideButtons, gamepasses
	if curOrigColor == nil then curOrigColor = gamepasses.BackgroundColor3 end

	wireButton(gamepasses)

	-- Restore the green state instantly if it was active before a rebuild
	if gamepassActive then setActive(true) end
end

-- Hook one inner TradeLiveTrade frame: build now, and rebuild instantly on changes
local function hookInner(inner)
	if inner:GetAttribute("GP_Hooked") then return end
	inner:SetAttribute("GP_Hooked", true)

	ensureButton()

	inner:GetPropertyChangedSignal("Visible"):Connect(ensureButton)

	local side = inner:FindFirstChild("Side Buttons")
	if side then
		side.ChildRemoved:Connect(function(child)
			if child.Name == "Gamepasses" then task.defer(ensureButton) end
		end)
	end
	inner.DescendantAdded:Connect(function(d)
		if d.Name == "Brainrots" or d.Name == "Side Buttons" then ensureButton() end
	end)
end

local function hookScreen(screen)
	local inner = screen:FindFirstChild("TradeLiveTrade")
	if inner then hookInner(inner) end
	screen.ChildAdded:Connect(function(c)
		if c.Name == "TradeLiveTrade" then hookInner(c) end
	end)
end

local existingScreen = playerGui:FindFirstChild("TradeLiveTrade")
if existingScreen then hookScreen(existingScreen) end
playerGui.ChildAdded:Connect(function(c)
	if c.Name == "TradeLiveTrade" then hookScreen(c) end
end)
