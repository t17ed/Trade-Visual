local function createAdminPanel(preset)
    local clone = template:Clone()
    clone.Name = "AdminPanel"
    clone.Parent = scrollingFrame
    clone.Visible = true

    -- place this item right below the Gamepasses label
    spawnCount += 1
    if gamepassLabel then
        clone.LayoutOrder = gamepassLabel.LayoutOrder + spawnCount
    else
        clone.LayoutOrder = 100000 + spawnCount
    end

    local spacer = clone:WaitForChild("Spacer")
    local cash   = spacer:WaitForChild("Cash")
    local title  = spacer:WaitForChild("Title")
    local stroke = spacer:FindFirstChildOfClass("UIStroke")

    cash.Text  = preset.Cash
    title.Text = preset.Title
    spacer.BackgroundColor3 = defaultColor
    if stroke then stroke.Color = Color3.fromRGB(0,0,0) end

    clone:SetAttribute("Clicked", false)
    clone:SetAttribute("PresetName", preset.Name)

    local img = spacer:FindFirstChild("CustomImage")
    if not img then
        img = Instance.new("ImageLabel")
        img.Name = "CustomImage"
        img.BackgroundTransparency = 1
        img.Size = UDim2.new(0.5,0,0.5,0)
        img.Position = UDim2.new(0.25,0,0.25,0)
        img.Parent = spacer
    end
    img.Image = preset.Image

    spacer.InputBegan:Connect(function(input)
        if acceptLocked then return end          -- locked once trade hits ACCEPT
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            playSound("rbxassetid://75311202481026", 1)
            if clone:GetAttribute("Clicked") then
                clone:SetAttribute("Clicked", false)
                spacer.BackgroundColor3 = defaultColor
                if stroke then stroke.Color = Color3.fromRGB(0,0,0) end
                showNotification('Removed "'..preset.Title..'" from trade!', Color3.fromRGB(255,0,0))
                playSound("rbxassetid://126210834885859", 0.5)
                return
            end
            pendingPanel = clone
            confirmationUI.Enabled = true
            warningTemplate.Visible = true
        end
    end)

    table.insert(adminPanels, clone)
end

local function getVisibleCount(name)
    local count = 0
    for _, v in ipairs(adminPanels) do
        if v and v.Parent and v.Visible and v:GetAttribute("PresetName") == name then
            count += 1
        end
    end
    return count
end

local function removePreset(name)
    for i = #adminPanels, 1, -1 do
        local panel = adminPanels[i]
        if panel and panel.Parent and panel:GetAttribute("PresetName") == name and panel.Visible then
            panel.Visible = false
            removedPresets[panel] = true
            showNotification('Removed "'..name..'" preset!', Color3.fromRGB(255,0,0))
            break
        end
    end
end

--====================================================================
--  ACCEPT-STAGE BEHAVIOUR  (visual only -- reads the button's .Text,
--  never fires/clicks it, never touches the server or other player)
--    * when the ready button text becomes "ACCEPT":
--        - every inserted card returns to its DEFAULT colour
--        - cards stop responding to clicks (acceptLocked guard above)
--    * when it leaves "ACCEPT", cards become interactive again
--====================================================================

-- read-only: what does the trade's ready button currently say?
local function getReadyText()
    local other = main:FindFirstChild("Other")
    if not other then return nil end
    local readyButton = other:FindFirstChild("ReadyButton")
    if not readyButton then return nil end
    local txt = readyButton:FindFirstChild("Txt")
    if not txt then return nil end
    return txt.Text
end

-- reset every inserted card to its default look
local function resetCardsToDefault()
    for _, panel in ipairs(adminPanels) do
        if panel and panel.Parent then
            panel:SetAttribute("Clicked", false)
            local spacer = panel:FindFirstChild("Spacer")
            if spacer then
                spacer.BackgroundColor3 = defaultColor
                local stroke = spacer:FindFirstChildOfClass("UIStroke")
                if stroke then stroke.Color = Color3.fromRGB(0,0,0) end
            end
        end
    end
end

task.spawn(function()
    while true do
        if getReadyText() == "ACCEPT" then
            if not acceptLocked then
                acceptLocked = true        -- blocks card clicks (see guard above)
                resetCardsToDefault()      -- cards go back to default colour
            end
        else
            acceptLocked = false           -- interactive again before ACCEPT
        end
        task.wait(0.05)
    end
end)

