	--// HIDE SELECTION HELPERS (only while green)
	local function hideSelections()
		for _, v in ipairs(scrollingFrame:GetChildren()) do
			if v:IsA("GuiObject") and v.Name:find("Selection") then
				v.Visible = false
			end
		end
	end
	scrollingFrame.ChildAdded:Connect(function()
		if isActive() then task.wait(); hideSelections() end
	end)
	task.spawn(function()
		while true do
			if isActive() then hideSelections() end
			task.wait(0.03)
		end
	end)

	--// RESET PANELS WHEN TRADE OPENS
	local function resetPanels()
		for _, panel in ipairs(adminPanels) do
			if panel and panel.Parent then
				if not removedPresets[panel] then
					panel.Visible = true
					panel:SetAttribute("Clicked", false)
					local spacer = panel:FindFirstChild("Spacer")
					if spacer then
						spacer.BackgroundColor3 = defaultColor
						local stroke = spacer:FindFirstChildOfClass("UIStroke")
						if stroke then stroke.Color = Color3.fromRGB(0, 0, 0) end
					end
				else
					panel.Visible = false
				end
			end
		end
	end
	tradeUI:GetPropertyChangedSignal("Visible"):Connect(function()
		if tradeUI.Visible then
			acceptProcessed = false
			resetPanels()
		end
	end)

	--// ACCEPT STATE (reads your game's ready button)
	local function getAcceptState()
		local other = tradeUI:FindFirstChild("Other")
		local readyButton = other and other:FindFirstChild("ReadyButton")
		local txt = readyButton and readyButton:FindFirstChild("Txt")
		return txt ~= nil and txt.Text == "ACCEPT"
	end

	--// CREATE A PANEL
	local function createAdminPanel(preset)
		if not template then
			showNotification("No Template found in ScrollingFrame!", Color3.fromRGB(255, 0, 0))
			return
		end
		local clone = template:Clone()
		clone.Name = "AdminPanel"
		clone.Visible = true
		clone.Parent = scrollingFrame
		clone:SetAttribute("Clicked", false)
		clone:SetAttribute("PresetName", preset.Name)

		local spacer = clone:FindFirstChild("Spacer")
		if spacer then
			local cash = spacer:FindFirstChild("Cash")
			local title = spacer:FindFirstChild("Title")
			if cash then cash.Text = preset.Cash end
			if title then title.Text = preset.Title end
			spacer.BackgroundColor3 = defaultColor
			local stroke = spacer:FindFirstChildOfClass("UIStroke")
			if stroke then stroke.Color = Color3.fromRGB(0, 0, 0) end

			local img = spacer:FindFirstChild("CustomImage")
			if not img then
				img = Instance.new("ImageLabel")
				img.Name = "CustomImage"
				img.BackgroundTransparency = 1
				img.Size = UDim2.new(0.5, 0, 0.5, 0)
				img.Position = UDim2.new(0.25, 0, 0.25, 0)
				img.Parent = spacer
			end
			img.Image = preset.Image

			spacer.InputBegan:Connect(function(input)
				if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
				playSound("rbxassetid://75311202481026", 1)

				if clone:GetAttribute("Clicked") then
					clone:SetAttribute("Clicked", false)
					spacer.BackgroundColor3 = defaultColor
					if stroke then stroke.Color = Color3.fromRGB(0, 0, 0) end
					showNotification('Removed "' .. preset.Title .. '" from trade!', Color3.fromRGB(255, 0, 0))
					playSound("rbxassetid://126210834885859", 0.5)
					return
				end
				if getAcceptState() then return end

				pendingPanel = clone
				askConfirm(preset.Title, function()
					playSound("rbxassetid://83245966620103", 0.5)
					if pendingPanel and pendingPanel.Parent then
						local sp = pendingPanel:FindFirstChild("Spacer")
						if sp then
							sp.BackgroundColor3 = clickedColor
							local st = sp:FindFirstChildOfClass("UIStroke")
							if st then st.Color = Color3.fromRGB(15, 255, 15) end
							pendingPanel:SetAttribute("Clicked", true)
						end
					end
					showNotification("Successfully added item to trade!", Color3.fromRGB(0, 255, 0))
				end, function()
					playSound("rbxassetid://126210834885859", 0.5)
					showNotification("Did not add item to trade.", Color3.fromRGB(255, 0, 0))
				end)
			end)
		end

		table.insert(adminPanels, clone)
	end

