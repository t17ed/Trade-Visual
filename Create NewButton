local function playSound(id, volume)
    local sound = Instance.new("Sound")
    sound.SoundId = id
    sound.Volume = volume or 1
    sound.Parent = playerGui
    sound:Play()
    Debris:AddItem(sound, 5)
end

local function neonText(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
        local existing = obj:FindFirstChild("Glow")
        if existing then existing:Destroy() end
        local glow = Instance.new("UIStroke")
        glow.Name = "Glow"
        glow.Color = neonPink
        glow.Thickness = 2
        glow.Parent = obj
    end
end

local function showNotification(text, color)
    if notificationCooldown[text] then return end
    notificationCooldown[text] = true
    task.delay(0.15, function() notificationCooldown[text] = nil end)

    local clone = notifTemplate:Clone()
    clone.Parent = notificationUI
    clone.Visible = true
    local txt = clone:IsA("TextLabel") and clone or clone:FindFirstChild("Text", true)
    if txt then
        txt.RichText = true
        txt.Text = text
        txt.TextColor3 = color
    end
    local originalPos = clone.Position
    clone.Position = originalPos + UDim2.new(0,300,0,0)
    TweenService:Create(clone, TweenInfo.new(0.25, Enum.EasingStyle.Quint), { Position = originalPos }):Play()
    task.delay(4, function()
        if clone and clone.Parent then
            TweenService:Create(clone, TweenInfo.new(0.2), { BackgroundTransparency = 1 }):Play()
            task.wait(0.2)
            if clone then clone:Destroy() end
        end
    end)
end

--====================================================================
--  CARD VISIBILITY  --  cards (gamepasses) show ONLY when the
--  "Gears + Gamepasses" button is GREEN
--====================================================================

local function coloursMatch(a, b)
    local tol = 0.5 / 255
    return math.abs(a.R - b.R) <= tol
        and math.abs(a.G - b.G) <= tol
        and math.abs(a.B - b.B) <= tol
end

local function gearsIsColour(target)
    if coloursMatch(gears.BackgroundColor3, target) then return true end
    if gears:IsA("ImageLabel") or gears:IsA("ImageButton") then
        return coloursMatch(gears.ImageColor3, target)
    end
    return false
end

-- show every (non-removed) card only when gears is green
local function refreshCards()
    local show = gearsIsColour(SHOW_COLOR)
    for _, panel in ipairs(adminPanels) do
        if panel and panel.Parent and not removedPresets[panel] then
            panel.Visible = show
        end
    end
end

-- debug slider target: size of the "Gears + Gamepasses" button text
local function applyGearsTxtSize()
    if gearsTxt:IsA("TextLabel") or gearsTxt:IsA("TextButton") or gearsTxt:IsA("TextBox") then
        gearsTxt.TextScaled = false
        gearsTxt.TextSize = gearsTxtSize
    end
end

refreshCards()
gears:GetPropertyChangedSignal("BackgroundColor3"):Connect(refreshCards)
if gears:IsA("ImageLabel") or gears:IsA("ImageButton") then
    gears:GetPropertyChangedSignal("ImageColor3"):Connect(refreshCards)
end

--====================================================================
--  RESET / TRADE-OPEN VISUALS
--====================================================================

local function resetPanels()
    for _, panel in ipairs(adminPanels) do
        if panel and panel.Parent and not removedPresets[panel] then
            panel:SetAttribute("Clicked", false)
            local spacer = panel:FindFirstChild("Spacer")
            if spacer then
                spacer.BackgroundColor3 = defaultColor
                local stroke = spacer:FindFirstChildOfClass("UIStroke")
                if stroke then stroke.Color = Color3.fromRGB(0,0,0) end
            end
        end
    end
    refreshCards()
end

main:GetPropertyChangedSignal("Visible"):Connect(function()
    if main.Visible then
        resetPanels()
    else
        if not warningTemplate.Visible then
            confirmationUI.Enabled = false
        end
    end
end)

--====================================================================
--  ACCEPT-STAGE BEHAVIOUR  (visual only -- reads the button's .Text,
--  never fires/clicks it, never touches the server or other player)
--====================================================================

local function getReadyText()
    local other = main:FindFirstChild("Other")
    if not other then return nil end
    local readyButton = other:FindFirstChild("ReadyButton")
    if not readyButton then return nil end
    local txt = readyButton:FindFirstChild("Txt")
    if not txt then return nil end
    return txt.Text
end

local function resetCardsToDefault()
    for _, panel in ipairs(adminPanels) do
        if panel and panel.Parent then
            panel:SetAttribute("Clicked", false)
            local spacer = panel:FindFirstChild("Spacer")
            if spacer then
                spacer.BackgroundColor3 = defaultColor
                local stroke = spacer:FindFirstChildOfClass("UIStroke")
                if stroke then stroke.Color = Color3.fromRGB(0,0,0) end
            end
        end
    end
end

task.spawn(function()
    while true do
        if getReadyText() == "ACCEPT" then
            if not acceptLocked then
                acceptLocked = true        -- blocks card clicks (see guard below)
                resetCardsToDefault()      -- cards go back to default colour
            end
        else
            acceptLocked = false           -- interactive again before ACCEPT
        end
        task.wait(0.05)
    end
end)

