--====================================================================
--  GEARS / GAMEPASSES LABELS  +  COLOR-GATED VISIBILITY
--====================================================================

local gearsLabel    -- created on demand
local gamepassLabel -- created on demand

local function coloursMatch(a, b)
    local tol = 0.5 / 255
    return math.abs(a.R - b.R) <= tol
        and math.abs(a.G - b.G) <= tol
        and math.abs(a.B - b.B) <= tol
end

local function gearsIsColour(target)
    if coloursMatch(gears.BackgroundColor3, target) then return true end
    if gears:IsA("ImageLabel") or gears:IsA("ImageButton") then
        return coloursMatch(gears.ImageColor3, target)
    end
    return false
end

local function setUnderlined(label, word)
    if label:IsA("TextLabel") or label:IsA("TextButton") or label:IsA("TextBox") then
        label.RichText = true
        label.Text = "<u>" .. word .. "</u>"
    end
end

--// apply the current slider size to both labels
local function applyTextSize()
    for _, lbl in ipairs({ gearsLabel, gamepassLabel }) do
        if lbl and lbl.Parent then
            if lbl:IsA("TextLabel") or lbl:IsA("TextButton") or lbl:IsA("TextBox") then
                lbl.TextScaled = false        -- so TextSize is respected
                lbl.TextSize = labelTextSize
            end
        end
    end
end

local function placeBelow(parent, target, item)
    local layout = parent:FindFirstChildWhichIsA("UIListLayout")
    if layout then
        local targetOrder = target.LayoutOrder
        for _, child in ipairs(parent:GetChildren()) do
            if child ~= item and child:IsA("GuiObject") and child.LayoutOrder > targetOrder then
                child.LayoutOrder += 1
            end
        end
        item.LayoutOrder = targetOrder + 1
    else
        local height = target.AbsoluteSize.Y
        if height <= 0 then height = target.Size.Y.Offset end
        local tPos = target.Position
        item.Position = UDim2.new(tPos.X.Scale, tPos.X.Offset, tPos.Y.Scale, tPos.Y.Offset + height + 4)
    end
end

local function buildLabels()
    if not gearsIsColour(SHOW_COLOR) then return end

    -- Gears label: above EVERYTHING (very low LayoutOrder)
    gearsLabel = scrollingFrame:FindFirstChild(GEARS_LABEL_NAME)
    if not gearsLabel then
        gearsLabel = txt1:Clone()
        gearsLabel.Name = GEARS_LABEL_NAME
        gearsLabel.LayoutOrder = -1000000
        setUnderlined(gearsLabel, "Gears")
        gearsLabel.Parent = scrollingFrame
    end

    -- Gamepasses label: below the trade's selection slot
    gamepassLabel = scrollingFrame:FindFirstChild(GAMEPASS_LABEL_NAME)
    if not gamepassLabel then
        for _, child in ipairs(scrollingFrame:GetChildren()) do
            if child:IsA("GuiObject")
                and child ~= gearsLabel
                and string.find(string.lower(child.Name), SELECTION_KEYWORD, 1, true)
            then
                gamepassLabel = gearsLabel:Clone()
                gamepassLabel.Name = GAMEPASS_LABEL_NAME
                setUnderlined(gamepassLabel, "Gamepasses")
                gamepassLabel.Parent = scrollingFrame
                placeBelow(scrollingFrame, child, gamepassLabel)
                break
            end
        end
    end

    applyTextSize()
end

--// show on green, hide on grey (64,86,97), otherwise leave as-is
local function updateVisibility()
    if gearsIsColour(HIDE_COLOR) then
        if gearsLabel then gearsLabel.Visible = false end
        if gamepassLabel then gamepassLabel.Visible = false end
    elseif gearsIsColour(SHOW_COLOR) then
        buildLabels()
        if gearsLabel then gearsLabel.Visible = true end
        if gamepassLabel then gamepassLabel.Visible = true end
    end
end

buildLabels()
updateVisibility()
gears:GetPropertyChangedSignal("BackgroundColor3"):Connect(updateVisibility)
if gears:IsA("ImageLabel") or gears:IsA("ImageButton") then
    gears:GetPropertyChangedSignal("ImageColor3"):Connect(updateVisibility)
end

