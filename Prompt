local coreGui = game:GetService("CoreGui")

print("[RobuxEditor] Waiting for FoundationOverlay...")

local foundationOverlay = coreGui:WaitForChild("FoundationOverlay")

print("T17eds Robux Spoofer init : Put in autoexecute")

local TARGET_TEXT =
'<font family="rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json" weight="400">robux</font> 536,374,194'

local hooked = {}

local function forceObject(obj)
	if not obj then
		return
	end

	if not (obj:IsA("TextLabel") or obj:IsA("TextButton")) then
		return
	end

	obj.RichText = true

	-- instant apply
	obj.Text = TARGET_TEXT

	-- avoid double-hooking
	if hooked[obj] then
		return
	end

	hooked[obj] = true

	print("[RobuxEditor] Hooked:", obj:GetFullName())

	-- sub 1ms times
	obj:GetPropertyChangedSignal("Text"):Connect(function()
		if obj.Text ~= TARGET_TEXT and obj.Visible then
			obj.Text = TARGET_TEXT
		end
	end)

	-- check visibility
	obj:GetPropertyChangedSignal("Visible"):Connect(function()
		if obj.Visible then
			obj.Text = TARGET_TEXT
		end
	end)

	-- force text
	task.spawn(function()
		while obj and obj.Parent do
			if obj.Visible then
				if obj.Text ~= TARGET_TEXT then
					obj.Text = TARGET_TEXT
				end

				if not obj.RichText then
					obj.RichText = true
				end
			end

			task.wait()
		end

		hooked[obj] = nil
	end)
end

-- scan
for _, descendant in ipairs(foundationOverlay:GetDescendants()) do
	if descendant.Name == "RobuxPrice" then
		forceObject(descendant)
	end
end

-- future hooks
foundationOverlay.DescendantAdded:Connect(function(descendant)
	if descendant.Name == "RobuxPrice" then
		print("[RobuxEditor] New RobuxPrice detected.")
		forceObject(descendant)
	end
end)

task.spawn(function()
	while task.wait(1) do
		for _, descendant in ipairs(foundationOverlay:GetDescendants()) do
			if descendant.Name == "RobuxPrice" then
				forceObject(descendant)
			end
		end
	end
end)
